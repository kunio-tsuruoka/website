---
import Layout from '../../layouts/layout.astro';
import { getCategoryCta } from '../../lib/column-cta-mapping';
import { type MicroCMSEnv, PILLAR_SLUGS, getColumns } from '../../lib/microcms';
import { Header } from '../header';
import JsonLd from '../seo/json-ld.astro';
import { PageHero } from '../ui/page-hero';

export interface Props {
  /** MicroCMS のカテゴリID（例: 'ai-development'） */
  categoryId: string;
  /** PageHero のバッジ文言（英語表記） */
  badge: string;
  /** カテゴリ名（見出し・パンくず・JSON-LDに使用） */
  title: string;
  /** PageHero のサブタイトル */
  subtitle: string;
  /** <title> タグ用 */
  metaTitle: string;
  /** meta description */
  metaDescription: string;
}

const { categoryId, badge, title, subtitle, metaTitle, metaDescription } = Astro.props;

const runtime = (Astro.locals as { runtime?: { env?: MicroCMSEnv } }).runtime;
const env = runtime?.env;

const pillarSlug = PILLAR_SLUGS[categoryId];
const allColumns = await getColumns(categoryId, env);
const pillar = pillarSlug ? allColumns.find((c) => c.id === pillarSlug) : undefined;
const articles = allColumns
  .filter((c) => c.id !== pillarSlug)
  .map((c) => ({
    id: c.id,
    title: c.title,
    description: c.description,
    publishedAt: c.publishedAt,
  }));

const categoryCta = getCategoryCta(categoryId);
const ctaSource = `column-category-${categoryId}`;
const withSource = (href: string) =>
  `${href}${href.includes('?') ? '&' : '?'}source=${encodeURIComponent(ctaSource)}`;
const primaryCtaHref = withSource(categoryCta.primary.href);
const secondaryCtaHref = categoryCta.secondary ? withSource(categoryCta.secondary.href) : undefined;
---

<Layout title={metaTitle} description={metaDescription}>
  <JsonLd
    slot="head"
    type="breadcrumb"
    data={{
      items: [
        { name: 'ホーム', url: '/' },
        { name: 'コラム', url: '/column' },
        { name: title, url: `/column/${categoryId}` },
      ],
    }}
  />
  {allColumns.length > 0 && (
    <JsonLd
      slot="head"
      type="itemList"
      data={{
        name: `${title} コラム一覧`,
        url: `https://beekle.jp/column/${categoryId}`,
        itemType: 'Article',
        items: allColumns.map((a) => ({
          name: a.title,
          ...(a.description ? { description: a.description } : {}),
          url: `https://beekle.jp/column/${a.id}`,
        })),
      }}
    />
  )}
  <Header client:load />
  <main class="pt-20">
    <PageHero title={title} subtitle={subtitle} badge={badge} />

    <section class="relative overflow-hidden py-16 md:py-24">
      <div class="absolute -left-24 top-24 h-72 w-72 rounded-full bg-primary-100/40 blur-3xl" aria-hidden="true"></div>
      <div class="absolute -right-20 bottom-40 h-64 w-64 rounded-full bg-secondary-100/40 blur-3xl" aria-hidden="true"></div>
      <div class="decoration-dot dot-cyan absolute right-[10%] top-32 hidden h-2.5 w-2.5 lg:block" aria-hidden="true"></div>
      <div class="decoration-dot dot-yellow absolute left-[8%] bottom-48 hidden h-2 w-2 lg:block" aria-hidden="true"></div>
      <div class="container relative mx-auto px-6 md:px-8 max-w-5xl">
        {pillar && (
          <a
            href={`/column/${pillar.id}`}
            class="group relative mb-12 block overflow-hidden rounded-3xl border-2 border-primary-200 bg-gradient-to-br from-primary-50 to-white p-6 shadow-soft transition-all hover:-translate-y-0.5 hover:border-primary-400 hover:shadow-medium md:p-8"
          >
            <div class="pointer-events-none absolute -right-12 -top-12 h-40 w-40 rounded-full bg-primary-100/70 blur-2xl" aria-hidden="true"></div>
            <div class="relative">
              <p class="mb-3 flex items-center gap-2 text-xs font-bold tracking-wide text-primary-500">
                <span class="inline-flex items-center rounded-full bg-primary-500 px-3 py-1 text-white">完全ガイド</span>
                まず読む1本
              </p>
              <h2 class="text-xl font-bold leading-tight text-gray-900 transition-colors group-hover:text-primary-500 md:text-2xl">
                {pillar.title}
              </h2>
              {pillar.description && (
                <p class="mt-3 text-sm leading-relaxed text-gray-600 line-clamp-3">
                  {pillar.description}
                </p>
              )}
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-bold text-primary-500">
                ガイドを読む
                <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </span>
            </div>
          </a>
        )}

        <div class="grid gap-5 md:grid-cols-2">
          {articles.map((article) => (
            <a
              href={`/column/${article.id}`}
              class="group flex flex-col rounded-2xl border border-gray-100 bg-white p-6 shadow-soft transition-all hover:-translate-y-0.5 hover:border-primary-200 hover:shadow-medium"
            >
              <time class="text-sm text-gray-500">
                {new Date(article.publishedAt).toLocaleDateString('ja-JP')}
              </time>
              <h2 class="mt-2 text-lg font-bold leading-tight text-gray-900 transition-colors group-hover:text-primary-500">
                {article.title}
              </h2>
              {article.description && (
                <p class="mt-2 text-sm leading-relaxed text-gray-600 line-clamp-3">
                  {article.description}
                </p>
              )}
              <span class="mt-auto inline-flex items-center gap-1 pt-4 text-sm font-medium text-primary-500">
                記事を読む
                <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </span>
            </a>
          ))}
        </div>

        {allColumns.length === 0 && (
          <div class="text-center py-16 bg-gray-50 rounded-2xl">
            <p class="text-gray-500">
              記事を読み込めませんでした。しばらくしてから再度お試しください。
            </p>
          </div>
        )}

        <div class="relative mt-16 overflow-hidden rounded-3xl bg-accent-950 p-6 text-center text-white shadow-strong md:p-8">
          <div class="pointer-events-none absolute -left-16 -top-16 h-48 w-48 rounded-full bg-primary-500/25 blur-3xl" aria-hidden="true"></div>
          <div class="pointer-events-none absolute -bottom-16 -right-16 h-48 w-48 rounded-full bg-secondary-500/15 blur-3xl" aria-hidden="true"></div>
          <div class="relative">
          <h2 class="text-lg md:text-xl font-bold mb-3">{categoryCta.heading}</h2>
          <p class="text-white/80 text-sm leading-relaxed mb-6">
            {categoryCta.primaryDescription}。
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a
              href={primaryCtaHref}
              data-cta-source={ctaSource}
              data-cta-id={categoryCta.primary.ctaId}
              class="inline-flex items-center justify-center px-6 py-3 min-h-[44px] bg-primary-500 text-white rounded-full text-sm font-semibold hover:bg-primary-600 transition-colors"
            >
              {categoryCta.primary.label}
            </a>
            {categoryCta.secondary && secondaryCtaHref && (
              <a
                href={secondaryCtaHref}
                data-cta-source={ctaSource}
                data-cta-id={categoryCta.secondary.ctaId}
                class="inline-flex items-center justify-center px-6 py-3 min-h-[44px] bg-white/10 border border-white/30 text-white rounded-full text-sm font-semibold hover:bg-white/20 transition-colors"
              >
                {categoryCta.secondary.label}
              </a>
            )}
          </div>
          {categoryCta.secondary && (
            <p class="text-xs text-white/60 mt-4">
              {categoryCta.secondary.description}
            </p>
          )}
          </div>
        </div>

        <div class="mt-12 text-center">
          <a
            href="/column"
            class="inline-flex items-center text-primary-500 hover:text-primary-600 font-semibold transition-colors group py-3"
          >
            <svg
              class="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            <span>コラム一覧を見る</span>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
