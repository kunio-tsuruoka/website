---
// 全ページ共通フッター（layout.astro から静的に読み込む / hydration 不要）
const year = new Date().getFullYear();

const columns: { heading: string; links: { label: string; href: string }[] }[] = [
  {
    heading: '会社情報',
    links: [
      { label: '会社概要', href: '/company' },
      { label: 'Beekleの強み', href: '/strengths' },
      { label: 'メンバー紹介', href: '/members' },
      { label: '導入事例', href: '/case-studies' },
      { label: 'お客様の声', href: '/testimonial' },
      { label: '採用情報', href: '/careers' },
    ],
  },
  {
    heading: 'サービス',
    links: [
      { label: '生成AI受託開発', href: '/services/ai-development' },
      { label: 'RAGシステム構築', href: '/services/rag-system-development' },
      { label: 'AIチャットボット開発', href: '/services/ai-chatbot-development' },
      { label: 'OCR・帳票読み取りAI', href: '/services/ocr-ai-development' },
      { label: 'WEB・モバイルアプリ開発', href: '/services/web-mobile-development' },
      { label: 'CDP構築・顧客データ基盤', href: '/services/cdp-development' },
    ],
  },
  {
    heading: 'ナレッジ・ツール',
    links: [
      { label: 'コラム', href: '/column' },
      { label: 'ナレッジ', href: '/knowledge' },
      { label: '一問一答（よくある質問）', href: '/qa' },
      { label: '発注準備キット', href: '/tools' },
      { label: '資料ダウンロード', href: '/materials' },
    ],
  },
];
---

<footer class="bg-navy-950 text-white/80">
  <div class="container mx-auto px-6 py-14">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-4">
      <div class="md:pr-6">
        <a href="/" class="inline-flex min-h-[44px] items-center font-Poppins text-2xl font-bold text-white">Beekle</a>
        <p class="mt-4 text-sm leading-relaxed text-white/60">
          初期費用0円のゼロスタートで、動くプロトタイプを見てから判断できるAI・システム開発会社です。
        </p>
        <a
          href="/contact"
          class="mt-6 inline-flex min-h-[44px] items-center rounded-full bg-primary-500 px-6 py-2 text-sm font-bold text-white transition-colors hover:bg-primary-600"
        >
          お問い合わせ
        </a>
      </div>

      {
        columns.map((col) => (
          <nav aria-label={col.heading}>
            <h2 class="font-Montserrat text-sm font-bold tracking-wide text-white">{col.heading}</h2>
            <ul class="mt-4 space-y-1">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="flex min-h-[44px] items-center text-sm text-white/70 transition-colors hover:text-white"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div
      class="mt-12 flex flex-col gap-4 border-t border-white/10 pt-6 md:flex-row md:items-center md:justify-between"
    >
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
        <a href="/privacy" class="flex min-h-[44px] items-center text-white/70 transition-colors hover:text-white">
          プライバシーポリシー
        </a>
        <a href="/company" class="flex min-h-[44px] items-center text-white/70 transition-colors hover:text-white">
          会社概要
        </a>
      </div>
      <p class="text-sm text-white/50">© {year} Beekle. All rights reserved.</p>
    </div>
  </div>
</footer>
