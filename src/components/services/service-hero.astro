---
import type { ServiceDetail } from '@/types/service';

type Metric = { label: string; value: string };
type Illustration = { src: string; alt: string; stages: readonly string[] };

interface Props {
  service: ServiceDetail;
  config?: {
    eyebrow: string;
    headline?: string;
    heroLead: string;
    primaryOutcome: string;
    visualTitle: string;
    visualSubtitle: string;
    visualItems: readonly string[];
    illustration?: Illustration;
    metrics: readonly Metric[];
  };
}

const { service, config } = Astro.props;
const benefits = service.benefits.slice(0, 3);
---

<!-- ライト基調ヒーロー（2026-07-07 ユーザー指定）。
     ワーキングメモリ配慮: 左=バッジ/見出し/リード/CTAの4要素、右=ビジュアル1点のみ。
     旧: 紺背景+右パネル11要素（チップ・メトリクス・紺ボックス）は情報過多のため撤去 -->
<section class="relative overflow-hidden bg-white pt-28 pb-16 md:pt-32 md:pb-20">
  <div
    class="pointer-events-none absolute -right-32 -top-24 h-96 w-96 rounded-full bg-primary-100/60 blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute -left-24 bottom-0 h-72 w-72 rounded-full bg-primary-50 blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="container relative mx-auto px-6 lg:px-12">
    <div class="grid gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div>
        <span
          class="inline-flex items-center gap-2 rounded-full bg-primary-50 px-4 py-2 text-sm font-semibold text-primary-700"
        >
          <span class="h-2 w-2 rounded-full bg-primary-500" aria-hidden="true"></span>
          {config?.eyebrow ?? 'Beekle のサービス'}
        </span>
        <h1
          class="mt-6 max-w-4xl text-4xl font-bold leading-tight text-navy-950 md:text-5xl lg:text-6xl"
        >
          {config?.headline ?? service.title}
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-neutral-600 md:text-xl">
          {config?.heroLead ?? service.description}
        </p>
        {
          config?.primaryOutcome && (
            <p class="mt-5 max-w-2xl border-l-4 border-primary-500 pl-4 text-base font-semibold leading-relaxed text-navy-950">
              {config.primaryOutcome}
            </p>
          )
        }
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a
            href={`/contact?source=services-${service.id}-hero`}
            data-cta-source={`services-${service.id}-hero`}
            data-cta-id="contact"
            class="inline-flex min-h-[52px] items-center justify-center rounded-full bg-primary-500 px-8 py-3 text-base font-bold text-white shadow-soft transition hover:bg-primary-600 hover:shadow-medium"
          >
            無料相談する
            <svg class="ml-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
          <a
            href="/prooffirst"
            class="inline-flex min-h-[52px] items-center justify-center rounded-full border-2 border-primary-200 px-8 py-3 text-base font-bold text-primary-700 transition hover:border-primary-400 hover:bg-primary-50"
          >
            初期費用0円で始める
          </a>
        </div>
      </div>

      {
        config?.illustration ? (
          <figure class="overflow-hidden rounded-3xl shadow-strong">
            <img
              src={config.illustration.src}
              alt={config.illustration.alt}
              class="aspect-[1.9/1] w-full object-cover"
              width="950"
              height="500"
              loading="eager"
              decoding="async"
            />
          </figure>
        ) : (
          <div class="grid gap-3">
            {(config?.visualItems ?? benefits).map((item, index) => (
              <div class="flex items-center gap-3 rounded-2xl border border-neutral-100 bg-white px-5 py-4 shadow-soft">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary-500 font-Poppins text-sm font-bold text-white">
                  {index + 1}
                </span>
                <span class="font-bold text-navy-950">{item}</span>
              </div>
            ))}
          </div>
        )
      }
    </div>
  </div>
</section>
