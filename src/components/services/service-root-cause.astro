---
// 「なぜその問題が起きるのか」を可視化するセクション（生成AIサービスLP共通）
// 共感(PainPoints)と解決策(Solutions)の間に置き、原因を腹落ちさせてから商品提案へ進める。
// design.md: 1画面1アクセント(primary+neutral) / 通し番号ラベルは付けない。
interface Cause {
  title: string;
  description: string;
}

interface RootCause {
  eyebrow: string;
  title: string;
  lead?: string;
  causes: Cause[];
}

interface Props {
  rootCause?: RootCause;
}

const { rootCause } = Astro.props;
---

{rootCause && (
  <section id="root-cause" class="relative overflow-hidden bg-white py-20 md:py-28">
    <div class="absolute -right-24 top-16 h-64 w-64 rounded-full bg-primary-100/40 blur-3xl" aria-hidden="true"></div>
    <div class="decoration-dot dot-purple absolute left-[9%] top-24 hidden h-2 w-2 lg:block" aria-hidden="true"></div>
    <div class="container relative mx-auto px-6 lg:px-12">
      <div class="max-w-3xl">
        <p class="text-sm font-bold tracking-wide text-primary-500">{rootCause.eyebrow}</p>
        <h2 class="mt-3 text-3xl font-bold leading-tight text-accent-950 md:text-4xl">
          {rootCause.title}
        </h2>
        {rootCause.lead && (
          <p class="mt-4 text-base leading-relaxed text-neutral-700 md:text-lg">{rootCause.lead}</p>
        )}
      </div>

      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {rootCause.causes.map((cause) => (
          <article class="relative rounded-2xl border border-primary-100 bg-white p-6 shadow-soft transition-all hover:-translate-y-1 hover:shadow-medium md:p-7">
            <span class="absolute left-0 top-6 h-10 w-1 rounded-r bg-primary-500" aria-hidden="true"></span>
            <h3 class="pl-3 text-lg font-bold leading-snug text-navy-950">{cause.title}</h3>
            <p class="mt-3 pl-3 text-sm leading-relaxed text-neutral-600 md:text-base">
              {cause.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>
)}
