---
import type { ServiceDetail } from '@/types/service';

interface Props {
  sections: NonNullable<ServiceDetail['additionalSections']>;
}

const { sections } = Astro.props;

function getLead(paragraphs: string[]) {
  return paragraphs[0] ?? '';
}

function getBody(paragraphs: string[]) {
  return paragraphs.slice(1);
}

function getSummaryText(text: string) {
  const firstSentence = text.split('。')[0];
  return firstSentence.length > 72 ? `${firstSentence.slice(0, 70)}…` : firstSentence;
}

const graphRagStorySteps = [
  {
    label: 'RAGの課題 1',
    title: '必要な情報が複数資料に分散する',
    text: '回答に必要な根拠が、仕様書・議事録・障害報告・問い合わせ履歴に分かれていると、通常RAGでは拾い切れないことがあります。',
  },
  {
    label: 'RAGの課題 2',
    title: '全体の流れを見落としやすい',
    text: 'チャンク単位で検索するため、文書全体の流れや背景を踏まえた判断が苦手です。',
  },
  {
    label: 'RAGの課題 3',
    title: '似た資料が多いとノイズが増える',
    text: '文書量が増えるほど似た内容の資料も増え、本当に必要な情報が検索結果に埋もれやすくなります。',
  },
  {
    label: 'GraphRAG',
    title: '情報のつながりから全体像を整理する',
    text: '資料同士の関係をたどることで、分散した根拠、背景、必要な確認先をまとめて見つけやすくします。',
  },
];

const graphRagAnswerItems = [
  {
    label: '原因候補',
    value: '3月の請求API変更後、月次締めの差分が増えています。',
  },
  {
    label: '影響範囲',
    value: '請求承認、月次締め、顧客別レポートに関係しています。',
  },
  {
    label: '確認先',
    value: '業務システム部Aさんと、3月12日の議事録を確認してください。',
  },
];

const graphRagReasons = [
  '分散した情報をたどりやすい',
  '文書全体の流れを踏まえやすい',
  '大規模な資料群でも文脈で絞り込みやすい',
];

const storySectionConfigs = [
  {
    match: '生成AI受託開発',
    heading: 'PoCで終わらせず、業務で使えるAIまで作る',
    subtitle: '技術デモではなく、現場に定着する仕組みとして設計',
    example: '「AIを入れたいが、何から始めれば成果につながるかわからない」',
    setup:
      'AI開発は、モデルを選んで画面を作るだけでは成果が出ません。業務フロー、データ、評価基準、運用担当まで決めて初めて、現場で使えるAIになります。',
    strengthTitle: 'Beekleが強い理由',
    strengthText:
      '課題整理からPoC、本番化、運用改善までを一気通貫で設計します。最初に「何をもって成功とするか」を決めるため、動くデモで終わらず、投資判断できる状態まで持っていけます。',
    steps: [
      {
        label: 'よくある失敗',
        title: 'とりあえずAIを試して終わる',
        text: 'デモは動いても、現場の業務や評価指標に接続されず、本番化の判断ができません。',
      },
      {
        label: 'Beekleの設計',
        title: '業務課題から逆算する',
        text: '削減したい工数、回答精度、利用者、運用体制を先に整理し、AI化すべき範囲を決めます。',
      },
      {
        label: '本番化',
        title: '評価と改善を組み込む',
        text: '評価データ、ログ分析、人間レビューを設計し、リリース後も品質を改善できる状態にします。',
      },
    ],
    before: 'モデル選定と簡易デモはできたが、現場にどう入れるか決まっていない。',
    after: '業務フロー、評価基準、運用方法まで決まり、本番投資の判断ができる。',
    reasons: ['課題整理から入る', '評価設計まで作る', '運用改善を前提にする'],
  },
  {
    match: 'キーワード検索とAI検索',
    heading: '社内資料を探す時間を、根拠つき回答に変える',
    subtitle: 'キーワード一致ではなく、質問の意味と文書構造から探す',
    example: '「出張時の経費精算の上限はいくら？」',
    setup:
      '社内規程やマニュアルは、言い回しが部署ごとに違い、答えが複数ページに分かれがちです。キーワード検索では大量の候補が出ても、結局人が読み比べる必要があります。',
    strengthTitle: 'Beekleが強い理由',
    strengthText:
      '文書の種類ごとに分割方法やメタデータを設計し、回答には根拠箇所を添えます。単なる検索窓ではなく、社内文書を業務で使える回答基盤に変えます。',
    steps: [
      {
        label: '現場の困りごと',
        title: '資料はあるのに見つからない',
        text: 'ファイル名や表現が揃っておらず、探す人の経験に依存します。',
      },
      {
        label: '通常検索',
        title: '候補が多くて読まされる',
        text: 'キーワードを含む資料は出ますが、どこが答えかまでは判断できません。',
      },
      {
        label: 'BeekleのAI検索',
        title: '答えと根拠を一緒に返す',
        text: '質問の意味を見て該当箇所を探し、根拠つきで回答します。',
      },
    ],
    before: '関連しそうな資料が大量に出て、利用者が自分で読む。',
    after: '質問への回答と根拠箇所が出るため、確認時間を短縮できる。',
    reasons: ['文書構造に合わせて設計', '根拠箇所を提示', '部署・文書種別で絞れる'],
  },
  {
    match: 'シナリオ型チャットボット',
    heading: '選択肢で迷わせず、自然な質問に答える',
    subtitle: 'FAQを読ませるのではなく、会話の中で解決する',
    example: '「出張後、いつまでに経費を出せばいい？」',
    setup:
      '利用者はFAQの正式名称を知りません。シナリオ型では聞き方が少し変わるだけで回答にたどり着けず、結局担当者への問い合わせに戻ります。',
    strengthTitle: 'Beekleが強い理由',
    strengthText:
      'LLMと社内ナレッジを組み合わせ、自然な言い回しでも該当する回答を返します。答えられない質問は有人に引き継ぎ、会話ログからFAQ改善まで回せる設計にします。',
    steps: [
      {
        label: '利用者',
        title: '正式な聞き方がわからない',
        text: 'FAQの項目名ではなく、自分の言葉で質問します。',
      },
      {
        label: 'シナリオ型',
        title: '分岐にない質問で止まる',
        text: '想定外の表現や複合質問に弱く、管理する分岐も増え続けます。',
      },
      {
        label: 'Beekleの設計',
        title: '回答・引き継ぎ・改善まで回す',
        text: '自然文回答、有人引き継ぎ、ログ分析を組み込み、運用で回答率を上げます。',
      },
    ],
    before: 'FAQを読んでもらえず、同じ質問が担当者に集中する。',
    after: '自然な質問に自動回答し、難しい質問だけ人に渡せる。',
    reasons: ['自然文に対応', '有人引き継ぎを設計', 'ログから改善できる'],
  },
  {
    match: 'テンプレート型OCR',
    heading: '帳票がバラバラでも、入力作業を減らす',
    subtitle: '固定テンプレートではなく、帳票の意味を読んで処理する',
    example: '「取引先ごとに請求書の形式が違い、毎回手入力している」',
    setup:
      '従来OCRは、決まった場所に決まった項目がある前提です。実際の業務では、取引先ごとに形式が違い、表記ゆれやレイアウト変更が頻繁に起きます。',
    strengthTitle: 'Beekleが強い理由',
    strengthText:
      'OCRで文字を読み取り、LLMで項目の意味を解釈します。確信度が低い箇所だけ人が確認するレビュー導線も作るため、精度と運用効率を両立できます。',
    steps: [
      {
        label: '現場',
        title: 'フォーマットが統一されない',
        text: '取引先や年度によって請求書・帳票の見た目が変わります。',
      },
      {
        label: 'テンプレートOCR',
        title: '変更のたびに設定が増える',
        text: '座標指定に依存するため、新しい形式が来るたびに調整が必要です。',
      },
      {
        label: 'Beekleの設計',
        title: '項目の意味で読み取る',
        text: '表記や位置が違っても、文脈から金額・日付・取引先などを抽出します。',
      },
    ],
    before: '帳票形式が増えるたびに設定と目視確認が増える。',
    after: '新しい形式にも対応しやすく、確認すべき箇所だけ人が見る。',
    reasons: ['形式違いに強い', '確信度で確認箇所を絞る', '修正ログで改善できる'],
  },
  {
    match: 'チャットボットとAIエージェント',
    heading: '答えるだけでなく、業務を最後まで進める',
    subtitle: '複数システムをまたぐ作業を、安全に自動化する',
    example: '「在庫を確認して、足りなければ発注して、担当者に連絡して」',
    setup:
      'チャットボットは質問に答えるだけです。実際の業務では、調査、判断、システム入力、通知までが一連の作業になっています。',
    strengthTitle: 'Beekleが強い理由',
    strengthText:
      '既存システムと安全に連携し、AIが実行してよい範囲、人間承認が必要な範囲、監査ログを設計します。便利さだけでなく、業務リスクを抑えた実装にします。',
    steps: [
      {
        label: '依頼',
        title: '複数作業がつながっている',
        text: '在庫確認、発注判断、書類作成、通知が別システムに分かれています。',
      },
      {
        label: 'チャットボット',
        title: '手順の説明で止まる',
        text: '何をすべきかは答えられても、実際の処理は人が行います。',
      },
      {
        label: 'AIエージェント',
        title: '確認しながら実行する',
        text: '必要な情報を集め、条件に沿って処理し、重要操作は人間承認を挟みます。',
      },
    ],
    before: 'AIが手順を説明しても、担当者の作業は残る。',
    after: '調査・判断・実行・通知まで一連の業務として進められる。',
    reasons: ['複数システムと連携', '承認フローを組み込む', '操作ログを残せる'],
  },
];

function getStorySectionConfig(title: string) {
  return storySectionConfigs.find((config) => title.includes(config.match));
}
---

<section class="relative overflow-hidden bg-white py-20 md:py-28">
  <div class="container relative mx-auto px-6 lg:px-12">
    <div class="mx-auto max-w-5xl space-y-14">
      {
        sections.map((section, sectionIndex) => {
          const lead = getLead(section.paragraphs);
          const body = getBody(section.paragraphs);
          const summaryItems =
            section.cards && section.cards.length > 0
              ? section.cards.slice(0, 3).map((card) => card.title)
              : section.paragraphs.slice(0, 3).map(getSummaryText);
          const isGraphRagComparison = section.title.includes('通常のRAG');
          const storyConfig = getStorySectionConfig(section.title);

          return (
            <article class="rounded-3xl border border-neutral-200 bg-white p-6 shadow-soft md:p-8">
              <header>
                <p class="text-sm font-bold tracking-wide text-primary-500">
                  GUIDE {String(sectionIndex + 1).padStart(2, '0')}
                </p>
                <h2 class="mt-3 text-3xl font-bold leading-tight text-navy-950 md:text-4xl">
                  {isGraphRagComparison
                    ? 'GraphRAGなら、資料をまたいだ全体像までわかる'
                    : storyConfig
                      ? storyConfig.heading
                      : section.title}
                </h2>
                {section.subtitle && (
                  <p class="mt-3 text-base font-bold leading-relaxed text-primary-500 md:text-lg">
                    {isGraphRagComparison
                      ? '「資料を探すAI」と「状況を整理するAI」の違い'
                      : storyConfig
                        ? storyConfig.subtitle
                        : section.subtitle}
                  </p>
                )}
              </header>

              {isGraphRagComparison ? (
                <div class="mt-7 space-y-6">
                  <div class="rounded-3xl border border-primary-100 bg-primary-50 p-5 md:p-7">
                    <p class="text-sm font-bold text-primary-600">具体例</p>
                    <h3 class="mt-2 text-2xl font-bold leading-tight text-accent-950 md:text-3xl">
                      「請求金額が合わない。何が原因で、誰に確認すべき？」
                    </h3>
                    <p class="mt-4 text-base leading-relaxed text-neutral-800">
                      この質問は、1つの資料だけでは答えにくいです。仕様書、議事録、障害報告、問い合わせ履歴をまたいで、情報のつながりを見る必要があります。
                    </p>
                  </div>

                  <div class="rounded-3xl border border-neutral-200 bg-white p-5 md:p-6">
                    <p class="text-sm font-bold text-primary-600">精度が上がりやすい条件</p>
                    <h3 class="mt-2 text-2xl font-bold leading-tight text-accent-950">
                      必要な情報が複数資料・複数チャンクに分かれているとき
                    </h3>
                    <p class="mt-4 text-base leading-relaxed text-neutral-700">
                      通常RAGは、少数の資料に答えがまとまっている質問では強力です。一方で、答えに必要な情報が複数資料に分散している場合や、大量の資料から関係する情報だけを絞りたい場合、GraphRAGは部署・案件・時期・出来事などの文脈でたどれるため、より網羅的で判断しやすい回答になりやすいです。
                    </p>
                  </div>

                  <div class="grid gap-4 md:grid-cols-4">
                    {graphRagStorySteps.map((step, index) => (
                      <div class="rounded-3xl border border-neutral-200 bg-white p-5 shadow-sm">
                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-primary-500 text-sm font-bold text-white">
                          {index + 1}
                        </span>
                        <p class="mt-4 text-xs font-bold tracking-wide text-primary-600">
                          {step.label}
                        </p>
                        <h3 class="mt-2 text-lg font-bold leading-snug text-accent-950">
                          {step.title}
                        </h3>
                        <p class="mt-3 text-sm leading-relaxed text-neutral-700">{step.text}</p>
                      </div>
                    ))}
                  </div>

                  <div class="grid gap-4 md:grid-cols-[0.95fr_1.05fr]">
                    <div class="rounded-3xl border border-neutral-200 bg-neutral-50 p-5 md:p-6">
                      <p class="text-sm font-bold text-neutral-600">通常のRAGの回答</p>
                      <h3 class="mt-2 text-2xl font-bold leading-tight text-accent-950">
                        関連資料の一覧で止まりやすい
                      </h3>
                      <div class="mt-5 rounded-2xl bg-white p-4">
                        <p class="text-sm leading-relaxed text-neutral-700">
                          関連資料は「請求API仕様書」「3月12日の議事録」「障害報告」です。
                          それぞれ確認してください。
                        </p>
                      </div>
                      <p class="mt-4 text-sm leading-relaxed text-neutral-700">
                        資料は見つかります。ただし、資料同士がどう関係しているかは利用者が読み解く必要があります。
                      </p>
                    </div>

                    <div class="rounded-3xl border-2 border-primary-500 bg-white p-5 shadow-soft md:p-6">
                      <p class="text-sm font-bold text-primary-600">GraphRAGの回答</p>
                      <h3 class="mt-2 text-2xl font-bold leading-tight text-accent-950">
                        状況を整理して、次の確認先まで出せる
                      </h3>
                      <div class="mt-5 space-y-3">
                        {graphRagAnswerItems.map((item) => (
                          <div class="rounded-2xl bg-primary-50 p-4">
                            <p class="text-xs font-bold text-primary-600">{item.label}</p>
                            <p class="mt-1 text-sm font-bold leading-relaxed text-accent-950">
                              {item.value}
                            </p>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>

                  <div class="rounded-3xl bg-accent-950 p-5 md:p-6">
                    <p class="text-sm font-bold text-white">なぜ通常のRAGより強いのか</p>
                    <div class="mt-4 grid gap-3 md:grid-cols-3">
                      {graphRagReasons.map((reason) => (
                        <div class="rounded-2xl bg-white p-4">
                          <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-primary-500 text-sm font-bold text-white">
                            ✓
                          </span>
                          <p class="mt-3 text-sm font-bold leading-relaxed text-accent-950">
                            {reason}
                          </p>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              ) : storyConfig ? (
                <div class="mt-7 space-y-6">
                  <div class="rounded-3xl border border-primary-100 bg-primary-50 p-5 md:p-7">
                    <p class="text-sm font-bold text-primary-600">具体例</p>
                    <h3 class="mt-2 text-2xl font-bold leading-tight text-accent-950 md:text-3xl">
                      {storyConfig.example}
                    </h3>
                    <p class="mt-4 text-base leading-relaxed text-neutral-800">
                      {storyConfig.setup}
                    </p>
                  </div>

                  <div class="grid gap-4 md:grid-cols-3">
                    {storyConfig.steps.map((step, index) => (
                      <div class="rounded-3xl border border-neutral-200 bg-white p-5 shadow-sm">
                        <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-primary-500 text-sm font-bold text-white">
                          {index + 1}
                        </span>
                        <p class="mt-4 text-xs font-bold tracking-wide text-primary-600">
                          {step.label}
                        </p>
                        <h3 class="mt-2 text-lg font-bold leading-snug text-accent-950">
                          {step.title}
                        </h3>
                        <p class="mt-3 text-sm leading-relaxed text-neutral-700">{step.text}</p>
                      </div>
                    ))}
                  </div>

                  <div class="grid gap-4 md:grid-cols-[0.95fr_1.05fr]">
                    <div class="rounded-3xl border border-neutral-200 bg-neutral-50 p-5 md:p-6">
                      <p class="text-sm font-bold text-neutral-600">一般的な作り方</p>
                      <h3 class="mt-2 text-2xl font-bold leading-tight text-accent-950">
                        便利そうだが、現場に残る負担がある
                      </h3>
                      <div class="mt-5 rounded-2xl bg-white p-4">
                        <p class="text-sm leading-relaxed text-neutral-700">
                          {storyConfig.before}
                        </p>
                      </div>
                    </div>

                    <div class="rounded-3xl border-2 border-primary-500 bg-white p-5 shadow-soft md:p-6">
                      <p class="text-sm font-bold text-primary-600">Beekleの作り方</p>
                      <h3 class="mt-2 text-2xl font-bold leading-tight text-accent-950">
                        業務で使える状態まで設計する
                      </h3>
                      <div class="mt-5 rounded-2xl bg-primary-50 p-4">
                        <p class="text-sm font-bold leading-relaxed text-accent-950">
                          {storyConfig.after}
                        </p>
                      </div>
                    </div>
                  </div>

                  <div class="rounded-3xl border border-neutral-200 bg-white p-5 md:p-6">
                    <p class="text-sm font-bold text-primary-600">{storyConfig.strengthTitle}</p>
                    <p class="mt-3 text-base leading-relaxed text-neutral-700">
                      {storyConfig.strengthText}
                    </p>
                    <div class="mt-5 grid gap-3 md:grid-cols-3">
                      {storyConfig.reasons.map((reason) => (
                        <div class="rounded-2xl bg-primary-50 p-4">
                          <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-primary-500 text-sm font-bold text-white">
                            ✓
                          </span>
                          <p class="mt-3 text-sm font-bold leading-relaxed text-accent-950">
                            {reason}
                          </p>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              ) : (
                <>
                  <div class="mt-7 grid gap-3 md:grid-cols-3">
                    {summaryItems.map((item, index) => (
                      <div class="rounded-2xl bg-primary-50 p-4">
                        <span class="flex h-8 w-8 items-center justify-center rounded-full bg-primary-500 text-sm font-bold text-white">
                          {index + 1}
                        </span>
                        <p class="mt-3 text-sm font-bold leading-relaxed text-accent-950">
                          {item}
                        </p>
                      </div>
                    ))}
                  </div>

                  {lead && (
                    <p class="mt-7 border-l-4 border-primary-500 bg-primary-50 py-4 pl-5 pr-4 text-lg font-bold leading-relaxed text-navy-950 md:text-xl">
                      {lead}
                    </p>
                  )}

                  {body.length > 0 && (
                    <div class="mt-6 grid gap-4">
                      {body.map((paragraph, index) => (
                        <section class="rounded-2xl bg-neutral-50 p-5 md:p-6">
                          <p class="text-xs font-bold tracking-wide text-primary-500">
                            POINT {String(index + 2).padStart(2, '0')}
                          </p>
                          <p class="mt-3 text-base leading-relaxed text-neutral-700 md:text-lg">
                            {paragraph}
                          </p>
                        </section>
                      ))}
                    </div>
                  )}

                  {section.cards && section.cards.length > 0 && (
                    <div class="mt-7 grid gap-4 md:grid-cols-2">
                      {section.cards.map((card, index) => (
                        <div class="rounded-2xl border border-primary-100 bg-primary-50/60 p-5">
                          <p class="text-xs font-bold text-primary-500">
                            {String(index + 1).padStart(2, '0')}
                          </p>
                          <h3 class="mt-2 text-lg font-bold leading-snug text-navy-950">
                            {card.title}
                          </h3>
                          <p class="mt-3 text-sm leading-relaxed text-neutral-700">
                            {card.description}
                          </p>
                          {card.link && (
                            <a
                              href={card.link.href}
                              class="mt-4 inline-flex items-center text-sm font-bold text-primary-600 hover:text-primary-700"
                            >
                              {card.link.label}
                              <svg
                                class="ml-1 h-4 w-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                              >
                                <path
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                  stroke-width="2"
                                  d="M9 5l7 7-7 7"
                                />
                              </svg>
                            </a>
                          )}
                        </div>
                      ))}
                    </div>
                  )}
                </>
              )}
            </article>
          );
        })
      }
    </div>
  </div>
</section>
