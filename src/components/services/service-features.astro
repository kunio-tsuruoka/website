---
import { SectionHeader } from '@/components/ui';
import type { ServiceDetail } from '@/types/service';

interface Props {
  features: ServiceDetail['features'];
}

const { features } = Astro.props;

// ブランド3色の番号チップローテーション（design.md §2）
const chipTones = ['bg-primary-100 text-primary-600'];
---

<section class="relative overflow-hidden bg-neutral-50 py-20 md:py-28">
  <div class="decoration-bar-cyan absolute -right-20 top-24 hidden h-2.5 w-56 opacity-25 lg:block" aria-hidden="true"></div>
  <div class="decoration-dot dot-purple absolute left-[7%] top-32 hidden h-2.5 w-2.5 lg:block" aria-hidden="true"></div>
  <div class="decoration-dot dot-yellow absolute right-[9%] bottom-28 hidden h-2 w-2 lg:block" aria-hidden="true"></div>
  <div class="container relative mx-auto px-6 lg:px-12">
    <SectionHeader
      client:visible
      title="サービス内容"
      subtitle="必要な機能を、業務導線に合わせて組み込みます"
      number="04"
      label="FEATURES"
    />
    <div class="grid gap-4 md:grid-cols-2">
      {features.map((feature, index) => (
        <article class="group rounded-2xl bg-white p-6 shadow-soft transition-all hover:-translate-y-1 hover:shadow-medium md:p-7">
          <div class="flex items-center gap-4">
            <span
              class:list={[
                'flex h-10 w-10 shrink-0 items-center justify-center rounded-full font-Poppins text-sm font-bold',
                chipTones[index % chipTones.length],
              ]}
              aria-hidden="true"
            >
              {String(index + 1).padStart(2, '0')}
            </span>
            <h3 class="text-lg font-bold leading-snug text-navy-950 group-hover:text-primary-600">{feature.title}</h3>
          </div>
          <p class="mt-4 text-sm leading-relaxed text-neutral-600 md:text-base">{feature.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
