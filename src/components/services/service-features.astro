---
import { SectionHeader } from '@/components/ui';
import type { ServiceDetail } from '@/types/service';

interface Props {
  features: ServiceDetail['features'];
}

const { features } = Astro.props;
---

<section class="relative overflow-hidden bg-gradient-to-br from-primary-50 via-white to-primary-50/30 py-20 md:py-28">
  <div class="container mx-auto px-6 lg:px-12">
    <SectionHeader
      client:load
      title="サービス内容"
      subtitle="必要な機能を、業務導線に合わせて組み込みます"
      number="04"
      label="FEATURES"
    />
    <div class="grid gap-4 md:grid-cols-2">
      {features.map((feature) => (
        <article class="rounded-2xl border border-white bg-white/85 p-6 shadow-soft backdrop-blur transition hover:-translate-y-1 hover:shadow-medium">
          <h3 class="text-lg font-bold leading-snug text-navy-950">{feature.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-neutral-600 md:text-base">{feature.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
