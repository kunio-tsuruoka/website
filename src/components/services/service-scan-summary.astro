---
import type { ServiceDetail } from '@/types/service';

interface Props {
  service: ServiceDetail;
}

const { service } = Astro.props;
const targetPain = service.painPoints[0];
const firstSolution = service.solutions[0];
const mainFeature = service.features[0];
---

<section class="bg-white py-14 md:py-18">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="mx-auto max-w-6xl rounded-3xl border border-neutral-200 bg-white p-5 shadow-soft md:p-6">
      <div class="grid gap-4 lg:grid-cols-3">
        <a href="#pain-points" class="group rounded-2xl bg-neutral-50 p-5 transition hover:bg-primary-50">
          <p class="text-xs font-bold tracking-wide text-primary-500">まず確認</p>
          <h2 class="mt-2 text-lg font-bold leading-snug text-navy-950 group-hover:text-primary-600">
            どんな課題に向いているか
          </h2>
          <p class="mt-3 text-sm leading-relaxed text-neutral-600">
            {targetPain?.title ?? service.description}
          </p>
        </a>

        <a href="#solutions" class="group rounded-2xl bg-neutral-50 p-5 transition hover:bg-primary-50">
          <p class="text-xs font-bold tracking-wide text-primary-500">次に理解</p>
          <h2 class="mt-2 text-lg font-bold leading-snug text-navy-950 group-hover:text-primary-600">
            Beekleが何を作るか
          </h2>
          <p class="mt-3 text-sm leading-relaxed text-neutral-600">
            {firstSolution?.title ?? mainFeature?.title ?? service.title}
          </p>
        </a>

        <a href="#case-studies" class="group rounded-2xl bg-neutral-50 p-5 transition hover:bg-primary-50">
          <p class="text-xs font-bold tracking-wide text-primary-500">最後に判断</p>
          <h2 class="mt-2 text-lg font-bold leading-snug text-navy-950 group-hover:text-primary-600">
            発注前に見るべき材料
          </h2>
          <p class="mt-3 text-sm leading-relaxed text-neutral-600">
            事例、機能、FAQで導入後の姿とリスクを確認できます。
          </p>
        </a>
      </div>
    </div>
  </div>
</section>
