---
const useCases = [
  {
    label: '社内問い合わせ',
    title: '資料を探して、根拠つきで答える',
    description: '規程、マニュアル、過去対応を横断し、確認先までわかる回答にします。',
    icon: 'M21 21l-4.3-4.3M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15z',
  },
  {
    label: '書類処理',
    title: '紙・PDFの転記を減らす',
    description: '請求書や申込書を読み取り、確認が必要な箇所だけ人に渡します。',
    icon: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M8 13h8M8 17h6',
  },
  {
    label: '定型業務',
    title: '調査・入力・通知をまとめて進める',
    description: '複数システムをまたぐ繰り返し作業を、承認フロー付きで自動化します。',
    icon: 'M6 3v6M18 15v6M6 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM18 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM6 9v1a4 4 0 0 0 4 4h4a4 4 0 0 1 4 4v-3',
  },
  {
    label: '判断支援',
    title: '情報を整理し、次の一手を出す',
    description: '散らばったデータをまとめ、担当者が判断しやすい形で提示します。',
    icon: 'M3 3v18h18M7 16l4-4 3 3 5-7',
  },
];

const steps = [
  {
    number: '01',
    title: '業務を選ぶ',
    description: '時間がかかる、ミスが出る、属人化している作業を見つけます。',
  },
  {
    number: '02',
    title: '小さく試す',
    description: '実際の業務に近いデータで、動くプロトタイプを作ります。',
  },
  {
    number: '03',
    title: '数字で判断する',
    description: '精度だけでなく、削減時間、確認工数、費用を測ります。',
  },
  {
    number: '04',
    title: '安全に広げる',
    description: '人の確認、権限管理、ログを組み込み、段階的に本番運用します。',
  },
];
---

<section class="relative overflow-hidden bg-white py-20 md:py-24">
  <div class="absolute -right-20 top-12 h-60 w-60 rounded-full bg-primary-100/50 blur-3xl"></div>
  <div class="absolute -left-16 bottom-10 h-52 w-52 rounded-full bg-secondary-100/40 blur-3xl"></div>
  <div class="decoration-dot dot-cyan absolute right-[14%] top-16 hidden h-2.5 w-2.5 lg:block" aria-hidden="true"></div>
  <div class="decoration-dot dot-yellow absolute left-[12%] top-40 hidden h-2 w-2 lg:block" aria-hidden="true"></div>

  <div class="container relative mx-auto px-6 lg:px-12">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-3xl">
        <p class="text-sm font-bold tracking-wide text-primary-500">GENERATIVE AI FOR BUSINESS</p>
        <h2 class="mt-3 text-3xl font-bold leading-tight text-accent-950 md:text-4xl">
          生成AIでできることを、<br class="hidden sm:block" />業務の言葉で整理する
        </h2>
        <p class="mt-4 text-base leading-relaxed text-neutral-700 md:text-lg">
          最初から技術を選ぶ必要はありません。まずは、時間がかかる作業や担当者に集中している業務から、効果を確認しやすい使い方を選びます。
        </p>
      </div>

      <div class="mt-9 grid gap-4 md:grid-cols-2">
        {useCases.map((useCase) => (
          <article class="rounded-3xl border border-neutral-200 bg-white p-5 shadow-soft transition hover:-translate-y-0.5 hover:border-primary-200 hover:shadow-medium md:p-6">
            <div class="flex items-start gap-4">
              <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-accent-950 text-white">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={useCase.icon}></path>
                </svg>
              </span>
              <div>
                <p class="text-xs font-bold tracking-wide text-primary-500">{useCase.label}</p>
                <h3 class="mt-1 text-lg font-bold leading-snug text-accent-950 md:text-xl">
                  {useCase.title}
                </h3>
              </div>
            </div>
            <p class="mt-4 text-sm leading-relaxed text-neutral-700 md:text-base">
              {useCase.description}
            </p>
          </article>
        ))}
      </div>

      <div class="relative mt-12 overflow-hidden rounded-3xl bg-accent-950 p-5 shadow-strong md:p-8">
        <div class="pointer-events-none absolute -right-16 -top-16 h-48 w-48 rounded-full bg-primary-500/20 blur-3xl" aria-hidden="true"></div>
        <div class="decoration-dot dot-cyan pointer-events-none absolute right-8 top-8 hidden h-2.5 w-2.5 opacity-70 md:block" aria-hidden="true"></div>
        <div class="decoration-dot dot-yellow pointer-events-none absolute right-16 top-14 hidden h-2 w-2 opacity-60 md:block" aria-hidden="true"></div>
        <div class="relative max-w-3xl">
          <p class="text-sm font-bold tracking-wide text-primary-200">HOW TO START</p>
          <h2 class="mt-2 text-2xl font-bold leading-tight text-white md:text-3xl">
            「AIを入れる」ではなく、効果を確かめながら進める
          </h2>
          <p class="mt-3 text-sm leading-relaxed text-white/85 md:text-base">
            完全自動化を急がず、人が確認できる状態から始めます。現場で使えるかを数字で見てから、任せる範囲を広げます。
          </p>
        </div>

        <div class="relative mt-7 grid gap-3 md:grid-cols-4">
          {steps.map((step, index) => (
            <article class="relative rounded-2xl bg-white p-4 md:p-5">
              <div class="flex items-center justify-between gap-3">
                <span class="text-sm font-bold text-primary-500">{step.number}</span>
                {index < steps.length - 1 && (
                  <span class="hidden text-primary-300 md:block" aria-hidden="true">→</span>
                )}
              </div>
              <h3 class="mt-3 text-lg font-bold text-accent-950">{step.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-neutral-700">{step.description}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
