---
import { SectionHeader } from '@/components/ui';
import type { ServiceDetail } from '@/types/service';

interface Props {
  caseStudies: ServiceDetail['caseStudies'];
}

const { caseStudies } = Astro.props;

const barColors = ['bg-primary-500', 'bg-secondary-500', 'bg-highlight-500'];
const lastIsWide = caseStudies.length > 1 && caseStudies.length % 2 === 1;
---

<section id="case-studies" class="relative overflow-hidden bg-white py-20 md:py-28">
  <div class="absolute -right-24 top-24 h-72 w-72 rounded-full bg-primary-100/40 blur-3xl" aria-hidden="true"></div>
  <div class="decoration-dot dot-purple absolute left-[8%] top-28 hidden h-2.5 w-2.5 lg:block" aria-hidden="true"></div>
  <div class="decoration-dot dot-cyan absolute right-[10%] bottom-24 hidden h-2 w-2 lg:block" aria-hidden="true"></div>
  <div class="container relative mx-auto px-6 lg:px-12">
    <SectionHeader
      client:visible
      title="導入事例"
      subtitle="どのような課題を、どう実装に落としたか"
      number="03"
      label="CASE STUDIES"
    />
    <div class="grid gap-6 lg:grid-cols-2">
      {caseStudies.map((caseStudy, index) => {
        const isWide = lastIsWide && index === caseStudies.length - 1;
        return (
          <article
            class:list={[
              'overflow-hidden rounded-3xl border border-neutral-200 bg-white shadow-soft transition hover:shadow-medium',
              isWide && 'lg:col-span-2',
            ]}
          >
            <div class:list={['h-2', barColors[index % barColors.length]]}></div>
            <div class="p-6 md:p-8">
              <h3 class="text-xl font-bold leading-snug text-navy-950">{caseStudy.title}</h3>
              <div class:list={['mt-6', isWide ? 'grid gap-5 lg:grid-cols-2 lg:gap-8' : 'space-y-5']}>
                <div class="space-y-5">
                  <div>
                    <p class="text-xs font-bold tracking-wide text-primary-500">課題</p>
                    <p class="mt-2 text-sm leading-relaxed text-neutral-700 md:text-base">{caseStudy.challenge}</p>
                  </div>
                  <div>
                    <p class="text-xs font-bold tracking-wide text-primary-500">解決策</p>
                    <p class="mt-2 text-sm leading-relaxed text-neutral-700 md:text-base">{caseStudy.solution}</p>
                  </div>
                </div>
                <div class="space-y-5">
                  <div class="rounded-2xl bg-neutral-50 p-4">
                    <p class="text-xs font-bold tracking-wide text-primary-500">成果</p>
                    <ul class="mt-3 space-y-2">
                      {caseStudy.results.map((result) => (
                        <li class="flex gap-2 text-sm font-medium leading-relaxed text-neutral-800">
                          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-primary-500"></span>
                          <span>{result}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                  {caseStudy.techStack && caseStudy.techStack.length > 0 && (
                    <div class="rounded-2xl border border-neutral-200 bg-white p-4">
                      <p class="text-xs font-bold tracking-wide text-primary-500">技術スタック・構成</p>
                      <ul class="mt-3 space-y-2">
                        {caseStudy.techStack.map((tech) => (
                          <li class="flex gap-2 text-sm leading-relaxed text-neutral-700">
                            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-secondary-500"></span>
                            <span>{tech}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
