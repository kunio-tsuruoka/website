---
import { SectionHeader } from '@/components/ui';
import type { ServiceDetail } from '@/types/service';

interface Props {
  caseStudies: ServiceDetail['caseStudies'];
}

const { caseStudies } = Astro.props;
---

<section id="case-studies" class="bg-white py-20 md:py-28">
  <div class="container mx-auto px-6 lg:px-12">
    <SectionHeader
      client:load
      title="導入事例"
      subtitle="どのような課題を、どう実装に落としたか"
      number="03"
      label="CASE STUDIES"
    />
    <div class="grid gap-6 lg:grid-cols-2">
      {caseStudies.map((caseStudy) => (
        <article class="overflow-hidden rounded-3xl border border-neutral-200 bg-white shadow-soft">
          <div class="h-2 bg-primary-500"></div>
          <div class="p-6 md:p-8">
            <h3 class="text-xl font-bold leading-snug text-navy-950">{caseStudy.title}</h3>
            <div class="mt-6 space-y-5">
              <div>
                <p class="text-xs font-bold tracking-wide text-primary-500">課題</p>
                <p class="mt-2 text-sm leading-relaxed text-neutral-700 md:text-base">{caseStudy.challenge}</p>
              </div>
              <div>
                <p class="text-xs font-bold tracking-wide text-primary-500">解決策</p>
                <p class="mt-2 text-sm leading-relaxed text-neutral-700 md:text-base">{caseStudy.solution}</p>
              </div>
              <div class="rounded-2xl bg-neutral-50 p-4">
                <p class="text-xs font-bold tracking-wide text-primary-500">成果</p>
                <ul class="mt-3 space-y-2">
                  {caseStudy.results.map((result) => (
                    <li class="flex gap-2 text-sm font-medium leading-relaxed text-neutral-800">
                      <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-primary-500"></span>
                      <span>{result}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
