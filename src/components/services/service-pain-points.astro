---
import { SectionHeader } from '@/components/ui';
import type { ServiceDetail } from '@/types/service';

interface Props {
  painPoints: ServiceDetail['painPoints'];
}

const { painPoints } = Astro.props;

const iconPaths = {
  code: 'M16 18l6-6-6-6M8 6l-6 6 6 6',
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  users:
    'M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
  search: 'M21 21l-4.3-4.3M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15z',
  database:
    'M12 3c4.97 0 9 1.34 9 3s-4.03 3-9 3-9-1.34-9-3 4.03-3 9-3zM3 6v6c0 1.66 4.03 3 9 3s9-1.34 9-3V6M3 12v6c0 1.66 4.03 3 9 3s9-1.34 9-3v-6',
  message: 'M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v8z',
  clock: 'M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20zM12 6v6l4 2',
  file: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M8 13h8M8 17h6',
  bot: 'M12 8V4H8M16 4h-4M6 8h12a2 2 0 0 1 2 2v7a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-7a2 2 0 0 1 2-2zM9 13h.01M15 13h.01M9 17h6',
  workflow:
    'M6 3v6M18 15v6M6 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM18 21a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM6 9v1a4 4 0 0 0 4 4h4a4 4 0 0 1 4 4v-3',
  chart: 'M3 3v18h18M7 16l4-4 3 3 5-7',
  alert:
    'M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0zM12 9v4M12 17h.01',
};

function getPainIcon(title: string) {
  if (/セキュリティ|社外秘|漏洩|ガバナンス|暴走/.test(title)) return iconPaths.shield;
  if (/リソース|負荷|属人|担当|人/.test(title)) return iconPaths.users;
  if (/検索|文書|RAG|ChatGPT|社内データ/.test(title)) return iconPaths.search;
  if (/データ|更新|フォーマット|帳票|OCR/.test(title)) return iconPaths.database;
  if (/質問|問い合わせ|チャット|サポート/.test(title)) return iconPaths.message;
  if (/時間|営業時間|PoC|本番化/.test(title)) return iconPaths.clock;
  if (/マニュアル|規程|PDF|ファイル/.test(title)) return iconPaths.file;
  if (/AI|エージェント|モデル|技術選定/.test(title)) return iconPaths.bot;
  if (/システム|連携|業務|統合/.test(title)) return iconPaths.workflow;
  if (/精度|品質|評価|効果/.test(title)) return iconPaths.chart;
  return iconPaths.alert;
}
---

<section id="pain-points" class="relative overflow-hidden bg-white py-20 md:py-28">
  <div class="absolute -left-24 top-20 h-72 w-72 rounded-full bg-primary-100/40 blur-3xl" aria-hidden="true"></div>
  <div class="absolute -right-20 bottom-16 h-64 w-64 rounded-full bg-secondary-100/40 blur-3xl" aria-hidden="true"></div>
  <div class="decoration-dot dot-cyan absolute right-[12%] top-24 hidden h-2.5 w-2.5 lg:block" aria-hidden="true"></div>
  <div class="decoration-dot dot-yellow absolute left-[10%] bottom-32 hidden h-2 w-2 lg:block" aria-hidden="true"></div>
  <div class="container relative mx-auto px-6 lg:px-12">
    <SectionHeader
      client:visible
      title="よくある課題"
      subtitle="まず、どこで止まりやすいかを整理します"
      number="01"
      label="PAIN POINTS"
    />
    <div class="grid gap-4 md:grid-cols-2">
      {painPoints.map((point, index) => (
        <article class="group rounded-2xl border border-neutral-200 bg-neutral-50 p-6 transition hover:-translate-y-0.5 hover:border-primary-200 hover:bg-white hover:shadow-soft">
          <div class="flex gap-5">
            <div class="flex shrink-0 flex-col items-center gap-2">
              <span class="flex h-14 w-14 items-center justify-center rounded-2xl bg-accent-950 text-white shadow-soft">
                <svg class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={getPainIcon(point.title)}></path>
                </svg>
              </span>
              <span class="rounded-full bg-white px-2.5 py-1 text-xs font-bold text-primary-500 ring-1 ring-neutral-200">
                {String(index + 1).padStart(2, '0')}
              </span>
            </div>
            <div>
              <h3 class="text-lg font-bold leading-snug text-navy-950 group-hover:text-primary-600">
                {point.title}
              </h3>
              <p class="mt-3 text-sm leading-relaxed text-neutral-600 md:text-base">
                {point.description}
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
