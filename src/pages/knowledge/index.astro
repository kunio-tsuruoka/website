---
import { Header } from '../../components/header';
import JsonLd from '../../components/seo/json-ld.astro';
import Layout from '../../layouts/layout.astro';
import { type MicroCMSEnv, getColumn } from '../../lib/microcms';

export const prerender = false;

// Knowledge section で公開する記事のスラッグ一覧
const KNOWLEDGE_SLUGS = [
  'gherkin-bdd-introduction',
  'ears-requirements-syntax-guide',
  'ears-gherkin-workflow',
];

// Cloudflare Pages SSR: ランタイム環境変数を取得
const runtime = (Astro.locals as { runtime?: { env?: MicroCMSEnv } }).runtime;
const env = runtime?.env;

// 各記事を MicroCMS から取得
const articles: Array<{
  id: string;
  title: string;
  description?: string;
  publishedAt: string;
}> = [];

for (const slug of KNOWLEDGE_SLUGS) {
  try {
    const column = await getColumn(slug, env);
    if (column) {
      articles.push({
        id: column.id,
        title: column.title,
        description: column.description,
        publishedAt: column.publishedAt,
      });
    }
  } catch (e) {
    console.error(`Failed to load knowledge article: ${slug}`, e);
  }
}
---

<Layout
  title="Beekleのナレッジ | Beekle"
  description="Beekleが実務で使っている技術・手法のナレッジベースです。Gherkin記法、EARS要件記法など、要件定義の実践テクニックを公開しています。"
>
  <JsonLd
    slot="head"
    type="breadcrumb"
    data={{
      items: [
        { name: 'ホーム', url: '/' },
        { name: 'ナレッジ', url: '/knowledge' },
      ],
    }}
  />
  {articles.length > 0 && (
    <JsonLd
      slot="head"
      type="itemList"
      data={{
        name: 'Beekle ナレッジ一覧',
        url: 'https://beekle.jp/knowledge',
        itemType: 'Article',
        items: articles.map((a) => ({
          name: a.title,
          ...(a.description ? { description: a.description } : {}),
          url: `https://beekle.jp/knowledge/${a.id}`,
        })),
      }}
    />
  )}
  <Header client:load />
  <main class="pt-20">
    {/* Hero Section */}
    <section class="relative bg-gradient-to-br from-secondary-500 to-secondary-600 py-20 overflow-hidden">
      <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
      <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl relative">
        <div class="text-center">
          <div class="inline-block mb-6">
            <span class="inline-flex items-center px-4 py-2 bg-white/20 backdrop-blur-sm text-white rounded-full text-sm font-medium">
              Knowledge Base
            </span>
          </div>
          <h1 class="text-4xl font-bold text-white sm:text-5xl mb-6">
            Beekleのナレッジ
          </h1>
          <p class="text-xl text-white/90 max-w-3xl mx-auto leading-relaxed">
            私たちが実務で使っている技術・手法のナレッジベースです
          </p>
        </div>
      </div>
    </section>

    {/* Articles */}
    <section class="py-16 md:py-24 bg-gradient-to-br from-gray-50 to-white">
      <div class="container mx-auto px-6 md:px-8 max-w-4xl">
        <div class="grid gap-8">
          {articles.map((article) => (
            <a
              href={`/knowledge/${article.id}`}
              class="group bg-white rounded-2xl shadow-md hover:shadow-xl transition-all p-8 border border-gray-100 hover:border-secondary-200"
            >
              <div class="flex items-start gap-6">
                <div class="flex-shrink-0 w-14 h-14 rounded-2xl bg-gradient-to-br from-secondary-100 to-secondary-200 flex items-center justify-center">
                  <svg class="w-7 h-7 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <h2 class="text-xl md:text-2xl font-bold text-gray-900 group-hover:text-secondary-500 transition-colors mb-3 leading-tight">
                    {article.title}
                  </h2>
                  {article.description && (
                    <p class="text-gray-600 leading-relaxed mb-4 line-clamp-3">
                      {article.description}
                    </p>
                  )}
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-gray-500">
                      {new Date(article.publishedAt).toLocaleDateString('ja-JP')}
                    </span>
                    <div class="flex items-center text-secondary-500 font-semibold text-sm group-hover:translate-x-1 transition-transform">
                      <span>読む</span>
                      <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </div>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>

        {articles.length === 0 && (
          <div class="text-center py-16 bg-gray-50 rounded-xl">
            <p class="text-gray-500">ナレッジ記事を読み込めませんでした。しばらくしてから再度お試しください。</p>
          </div>
        )}

        {/* Back to column */}
        <div class="mt-12 text-center">
          <a
            href="/column"
            class="inline-flex items-center text-secondary-500 hover:text-secondary-600 font-semibold transition-colors group py-3"
          >
            <svg class="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            <span>コラム一覧を見る</span>
          </a>
        </div>
      </div>
    </section>

    {/* CTA Section */}
    <section class="relative py-20 md:py-28 overflow-hidden bg-gradient-to-br from-secondary-500 to-secondary-600">
      <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
      <div class="container mx-auto px-6 md:px-8 relative">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
            ナレッジを活用して、発注準備を始めませんか？
          </h2>
          <p class="text-xl text-white/90 mb-10 leading-relaxed">
            Gherkin/EARS記法で要件をまとめたら、次は無料ツールで発注ドキュメントを作成できます。
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href="/tools"
              class="inline-flex items-center justify-center px-10 py-5 text-xl font-semibold text-secondary-500 bg-white rounded-full hover:bg-gray-100 transition-all shadow-xl hover:shadow-2xl"
            >
              発注準備ツールを使う
              <svg class="w-6 h-6 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
            <a
              href="/contact?source=knowledge-index"
              class="inline-flex items-center justify-center px-10 py-5 text-xl font-semibold text-white bg-transparent border-2 border-white rounded-full hover:bg-white hover:text-secondary-500 transition-all"
            >
              無料相談を予約する
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .bg-grid-pattern {
    background-image: linear-gradient(rgba(255, 255, 255, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.1) 1px, transparent 1px);
    background-size: 20px 20px;
  }
</style>
