---
import { Header } from '../../components/header';
import JsonLd from '../../components/seo/json-ld.astro';
import { PageHero } from '../../components/ui/page-hero';
import Layout from '../../layouts/layout.astro';
import { type MicroCMSEnv, getColumn } from '../../lib/microcms';

export const prerender = false;

const KNOWLEDGE_SLUGS = [
  'gherkin-bdd-introduction',
  'ears-requirements-syntax-guide',
  'ears-gherkin-workflow',
];

const runtime = (Astro.locals as { runtime?: { env?: MicroCMSEnv } }).runtime;
const env = runtime?.env;

const articles: Array<{
  id: string;
  title: string;
  description?: string;
  publishedAt: string;
}> = [];

for (const slug of KNOWLEDGE_SLUGS) {
  try {
    const column = await getColumn(slug, env);
    if (column) {
      articles.push({
        id: column.id,
        title: column.title,
        description: column.description,
        publishedAt: column.publishedAt,
      });
    }
  } catch (e) {
    console.error(`Failed to load knowledge article: ${slug}`, e);
  }
}
---

<Layout
  title="Beekleのナレッジ | Beekle"
  description="Beekleが実務で使っている技術・手法のナレッジベースです。Gherkin記法、EARS要件記法など、要件定義の実践テクニックを公開しています。"
>
  <JsonLd
    slot="head"
    type="breadcrumb"
    data={{
      items: [
        { name: 'ホーム', url: '/' },
        { name: 'ナレッジ', url: '/knowledge' },
      ],
    }}
  />
  {articles.length > 0 && (
    <JsonLd
      slot="head"
      type="itemList"
      data={{
        name: 'Beekle ナレッジ一覧',
        url: 'https://beekle.jp/knowledge',
        itemType: 'Article',
        items: articles.map((a) => ({
          name: a.title,
          ...(a.description ? { description: a.description } : {}),
          url: `https://beekle.jp/knowledge/${a.id}`,
        })),
      }}
    />
  )}
  <Header client:load />
  <main class="pt-20">
    <PageHero
      title="Beekleのナレッジ"
      subtitle="私たちが実務で使っている技術・手法のナレッジベースです"
      badge="Knowledge Base"
    />

    <section class="py-16 md:py-24">
      <div class="container mx-auto px-6 md:px-8 max-w-3xl">
        <div class="divide-y divide-gray-200">
          {articles.map((article) => (
            <a
              href={`/knowledge/${article.id}`}
              class="block py-8 first:pt-0 last:pb-0 group"
            >
              <time class="text-sm text-gray-500">
                {new Date(article.publishedAt).toLocaleDateString('ja-JP')}
              </time>
              <h2 class="text-lg md:text-xl font-bold text-gray-900 group-hover:text-primary-500 transition-colors mt-1 mb-2 leading-tight">
                {article.title}
              </h2>
              {article.description && (
                <p class="text-gray-600 text-sm leading-relaxed line-clamp-2">
                  {article.description}
                </p>
              )}
            </a>
          ))}
        </div>

        {articles.length === 0 && (
          <div class="text-center py-16 bg-gray-50 rounded-xl">
            <p class="text-gray-500">ナレッジ記事を読み込めませんでした。しばらくしてから再度お試しください。</p>
          </div>
        )}

        <div class="mt-12 text-center">
          <a
            href="/column"
            class="inline-flex items-center text-primary-500 hover:text-primary-600 font-semibold transition-colors group py-3"
          >
            <svg class="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            <span>コラム一覧を見る</span>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
