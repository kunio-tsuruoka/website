---
import { Header } from '@/components/header';
import JsonLd from '@/components/seo/json-ld.astro';
import { Section, SectionHeader } from '@/components/ui';
import { PageHero } from '@/components/ui/page-hero';
import { services } from '@/data/service';
import type { ServiceDetail } from '@/types/service';
import Layout from '../../layouts/layout.astro';

export const prerender = true;

export function getStaticPaths() {
  return services.map((service) => ({
    params: { id: service.id },
    props: { service },
  }));
}

interface Props {
  service: ServiceDetail;
}

const { service } = Astro.props as Props;
const siteUrl = 'https://beekle.jp';
const serviceUrl = `${siteUrl}/services/${service.id}`;
const seoTitle = service.seoTitle ?? service.title;
const seoDescription = service.seoDescription ?? service.description;
---

<Layout title={`${seoTitle} | Beekle`} description={seoDescription} canonical={serviceUrl}>
  <JsonLd
    slot="head"
    type="service"
    data={{
      serviceName: service.title,
      serviceDescription: service.description,
    }}
  />
  <JsonLd
    slot="head"
    type="breadcrumb"
    data={{
      items: [
        { name: 'ホーム', url: '/' },
        { name: 'サービス', url: '/' },
        { name: service.title, url: `/services/${service.id}` },
      ],
    }}
  />
  {service.faq.length > 0 && (
    <JsonLd
      slot="head"
      type="faq"
      data={{
        faqs: service.faq.map((f) => ({ question: f.question, answer: f.answer })),
      }}
    />
  )}
  <Header client:load />
  <main class="pt-20">
    <!-- Hero -->
    <PageHero
      title={service.title}
      subtitle={service.description}
    >
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-4 text-lg font-medium text-primary-500 bg-white rounded-full hover:bg-gray-100 transition-all shadow-lg hover:shadow-xl"
        >
          無料相談を予約する
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
        <a
          href="/prooffirst"
          class="inline-flex items-center justify-center px-8 py-4 text-lg font-medium text-white bg-transparent border-2 border-white rounded-full hover:bg-white hover:text-primary-500 transition-all"
        >
          ゼロスタートを見る
        </a>
      </div>
    </PageHero>

    <!-- Overview -->
    <Section variant="white" padding="lg" decoration="blursPurple">
      <div class="max-w-3xl mx-auto text-center relative z-10">
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed font-NotoSansJP">
          {service.longDescription}
        </p>
      </div>
    </Section>

    <!-- Pain Points -->
    <Section variant="navy" padding="lg" decoration="none">
      <div class="max-w-5xl mx-auto relative z-10">
        <SectionHeader
          client:load
          title="よくある課題"
          subtitle="お客様が直面している主な課題"
          number="01"
          label="PAIN POINTS"
          dark
        />
        <div class="grid md:grid-cols-2 gap-6">
          {service.painPoints.map((point, index) => (
            <div class="group bg-white/10 backdrop-blur-sm rounded-2xl p-8 border border-white/10 hover:bg-white/15 transition-all">
              <div class="flex items-start gap-5">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-gradient-to-br from-secondary-400 to-secondary-500 text-white flex items-center justify-center text-lg font-bold font-Poppins shadow-md">
                  {index + 1}
                </div>
                <div>
                  <h3 class="text-xl font-bold text-white mb-2 group-hover:text-secondary-300 transition-colors">
                    {point.title}
                  </h3>
                  <p class="text-white/70 leading-relaxed">
                    {point.description}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Section>

    <!-- Solutions -->
    <Section variant="lightPurple" padding="lg" decoration="blursCyan">
      <div class="max-w-5xl mx-auto relative z-10">
        <SectionHeader
          client:load
          title="解決方法"
          subtitle="私たちが提供する具体的な解決策"
          number="02"
          label="SOLUTIONS"
        />
        <div class="space-y-8">
          {service.solutions.map((solution) => (
            <div class="bg-white rounded-2xl p-8 md:p-10 shadow-soft border border-gray-100">
              <h3 class="text-2xl font-bold text-navy-950 mb-4 font-Montserrat">
                {solution.title}
              </h3>
              <p class="text-gray-600 mb-8 leading-relaxed text-lg">
                {solution.description}
              </p>
              <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-3">
                {solution.results.map((result) => (
                  <div class="flex items-center gap-2.5 bg-gradient-to-r from-primary-50 to-secondary-50 rounded-xl px-4 py-3">
                    <svg class="w-5 h-5 text-secondary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-sm font-medium text-gray-700">{result}</span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </Section>

    <!-- Case Studies -->
    <Section variant="white" padding="lg" decoration="blursPurple">
      <div class="max-w-5xl mx-auto relative z-10">
        <SectionHeader
          client:load
          title="導入事例"
          subtitle="実際のお客様の成功事例"
          number="03"
          label="CASE STUDIES"
        />
        <div class="grid md:grid-cols-2 gap-8">
          {service.caseStudies.map((caseStudy) => (
            <div class="bg-white rounded-2xl overflow-hidden shadow-soft hover:shadow-medium transition-all border border-gray-100">
              <div class="h-1 bg-gradient-to-r from-primary-500 to-primary-600"></div>
              <div class="p-8">
                <h3 class="text-xl font-bold text-navy-950 mb-6 font-Montserrat">
                  {caseStudy.title}
                </h3>
                <div class="space-y-4">
                  <div class="border-l-2 border-primary-300 pl-4">
                    <p class="text-sm font-bold text-primary-500 mb-1">課題</p>
                    <p class="text-gray-700">{caseStudy.challenge}</p>
                  </div>
                  <div class="border-l-2 border-primary-300 pl-4">
                    <p class="text-sm font-bold text-primary-500 mb-1">解決策</p>
                    <p class="text-gray-700">{caseStudy.solution}</p>
                  </div>
                  <div class="border-l-2 border-primary-300 pl-4">
                    <p class="text-sm font-bold text-primary-500 mb-1">成果</p>
                    <ul class="space-y-1">
                      {caseStudy.results.map((result) => (
                        <li class="flex items-start gap-2 text-gray-700">
                          <span class="text-primary-400 mt-1">-</span>
                          {result}
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Section>

    <!-- Features -->
    <Section variant="lightCyan" padding="lg" decoration="none">
      <div class="max-w-5xl mx-auto relative z-10">
        <SectionHeader
          client:load
          title="サービス内容"
          subtitle="提供サービスの詳細"
          number="04"
          label="FEATURES"
        />
        <div class="grid md:grid-cols-2 gap-6">
          {service.features.map((feature) => (
            <div class="group bg-white rounded-2xl p-8 shadow-soft hover:shadow-medium transition-all border border-gray-100 hover:border-secondary-200">
              <h3 class="text-xl font-bold text-navy-950 mb-3 group-hover:text-primary-500 transition-colors font-Montserrat">
                {feature.title}
              </h3>
              <p class="text-gray-600 leading-relaxed">
                {feature.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </Section>

    <!-- FAQ -->
    <Section variant="white" padding="lg" decoration="blursPurple">
      <div class="max-w-3xl mx-auto relative z-10">
        <SectionHeader
          client:load
          title="よくある質問"
          subtitle="お客様からよくいただく質問にお答えします"
          number="05"
          label="FAQ"
        />
        <div class="space-y-4">
          {service.faq.map((item) => (
            <div class="bg-white rounded-2xl shadow-soft border border-gray-100 overflow-hidden">
              <div class="p-6 md:p-8">
                <h3 class="text-lg font-bold text-navy-950 mb-3 flex items-start gap-3">
                  <span class="flex-shrink-0 w-8 h-8 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 text-white flex items-center justify-center text-sm font-bold font-Poppins">Q</span>
                  <span class="pt-1">{item.question}</span>
                </h3>
                <p class="text-gray-600 leading-relaxed ml-11">
                  {item.answer}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Section>

    <!-- CTA -->
    <section class="relative py-20 md:py-32 overflow-hidden bg-gradient-to-br from-primary-500 to-primary-600">
      <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
      <div class="container mx-auto px-6 md:px-8 max-w-4xl text-center relative z-10">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-6 font-Montserrat">
          お気軽にご相談ください
        </h2>
        <p class="text-xl text-white/90 mb-10 leading-relaxed">
          プロジェクトの規模や予算に応じて、最適なソリューションをご提案いたします。
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-10 py-5 text-xl font-semibold text-primary-500 bg-white rounded-full hover:bg-gray-100 transition-all shadow-xl hover:shadow-2xl hover:scale-105 transform"
          >
            無料相談を予約する
            <svg class="w-6 h-6 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
          <a
            href="/company"
            class="inline-flex items-center justify-center px-10 py-5 text-xl font-semibold text-white bg-transparent border-2 border-white rounded-full hover:bg-white hover:text-primary-500 transition-all"
          >
            会社概要を見る
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .bg-grid-pattern {
    background-image: linear-gradient(rgba(255, 255, 255, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.1) 1px, transparent 1px);
    background-size: 20px 20px;
  }
</style>
