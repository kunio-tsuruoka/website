---
import { Header } from '@/components/header';
import JsonLd from '@/components/seo/json-ld.astro';
import AiDevelopmentOverview from '@/components/services/ai-development-overview.astro';
import ServiceAdditionalSections from '@/components/services/service-additional-sections.astro';
import ServiceBusinessFlow from '@/components/services/service-business-flow.astro';
import ServiceCaseStudies from '@/components/services/service-case-studies.astro';
import ServiceContactCta from '@/components/services/service-contact-cta.astro';
import ServiceEngagementFlow from '@/components/services/service-engagement-flow.astro';
import ServiceFaq from '@/components/services/service-faq.astro';
import ServiceFeatures from '@/components/services/service-features.astro';
import ServiceHero from '@/components/services/service-hero.astro';
import ServicePainPoints from '@/components/services/service-pain-points.astro';
import ServiceRootCause from '@/components/services/service-root-cause.astro';
import ServiceSolutions from '@/components/services/service-solutions.astro';
import { Section, SectionHeader } from '@/components/ui';
import { getAiServicePageConfig } from '@/data/ai-service-page-config';
import { services } from '@/data/service';
import type { ServiceDetail } from '@/types/service';
import Layout from '../../layouts/layout.astro';

export const prerender = false;

const { id } = Astro.params;
const service: ServiceDetail | undefined = services.find((s) => s.id === id);

if (!service) {
  return new Response(null, { status: 404 });
}

const siteUrl = 'https://beekle.jp';
const serviceUrl = `${siteUrl}/services/${service.id}`;
const seoTitle = service.seoTitle ?? service.title;
const seoDescription = service.seoDescription ?? service.description;
const servicePageConfig = getAiServicePageConfig(service.id);
const faqNumber =
  service.id === 'ai-development'
    ? '07'
    : service.relatedColumns && service.relatedColumns.length > 0
      ? '06'
      : '05';
---

<Layout title={`${seoTitle} | Beekle`} description={seoDescription} canonical={serviceUrl}>
  <JsonLd
    slot="head"
    type="service"
    data={{
      serviceName: service.title,
      serviceDescription: service.description,
      url: serviceUrl,
      serviceType: service.title,
      image: `${siteUrl}/og-image.png`,
    }}
  />
  <JsonLd
    slot="head"
    type="breadcrumb"
    data={{
      items: [
        { name: 'ホーム', url: '/' },
        { name: service.title, url: `/services/${service.id}` },
      ],
    }}
  />
  {service.faq.length > 0 && (
    <JsonLd
      slot="head"
      type="faq"
      data={{
        faqs: service.faq.map((f) => ({ question: f.question, answer: f.answer })),
      }}
    />
  )}
  <Header client:idle />
  <main class="pt-20">
    <ServiceHero service={service} config={servicePageConfig} />
    <ServiceBusinessFlow flow={servicePageConfig?.flow} />
    {service.id === 'ai-development' && <AiDevelopmentOverview />}
    <ServicePainPoints painPoints={service.painPoints} />
    <ServiceRootCause rootCause={servicePageConfig?.rootCause} />
    <ServiceSolutions solutions={service.solutions} />

    <ServiceCaseStudies caseStudies={service.caseStudies} />
    {servicePageConfig && <ServiceContactCta serviceId={service.id} placement="cases" />}
    <ServiceFeatures features={service.features} />

    {service.additionalSections && service.additionalSections.length > 0 && (
      <ServiceAdditionalSections sections={service.additionalSections} />
    )}

    {servicePageConfig && <ServiceEngagementFlow />}

    {service.id === 'rag-system-development' && (
      <Section variant="light" padding="lg" decoration="none">
        <div class="max-w-5xl mx-auto relative z-10">
          <SectionHeader
            title="立場によって、始め方は変えられます"
            subtitle="小さく試したい担当者にも、事故らせたくない情シスにも"
          />
          <div class="grid md:grid-cols-2 gap-6">
            <div class="flex flex-col rounded-3xl border border-primary-200 bg-white p-6 shadow-soft md:p-8">
              <span class="inline-flex w-fit items-center gap-2 rounded-full bg-primary-50 px-3 py-1 text-xs font-bold text-primary-700">
                推進担当の方へ
              </span>
              <h3 class="mt-4 text-xl font-bold leading-snug text-navy-950 md:text-2xl">
                効きそうかを、0円デモで先に確かめる
              </h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-neutral-700 md:text-base">
                費用対効果の大きい一業務に絞って、初期費用0円で試作します。上長や情シスに見せられる「動くもの」から始められるので、大きく投資する前に判断できます。
              </p>
              <a
                href="/contact?source=services-rag-system-development-persona-owner&intent=zero-start"
                data-cta-source="services-rag-system-development-persona-owner"
                data-cta-id="contact-zero-start"
                class="mt-6 inline-flex min-h-[52px] items-center justify-center rounded-full bg-primary-500 px-6 py-3 text-base font-bold text-white shadow-soft transition hover:bg-primary-600 hover:shadow-medium"
              >
                0円デモから相談する
                <svg class="ml-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </a>
            </div>
            <div class="flex flex-col rounded-3xl border border-neutral-200 bg-white p-6 shadow-soft md:p-8">
              <span class="inline-flex w-fit items-center gap-2 rounded-full bg-neutral-100 px-3 py-1 text-xs font-bold text-neutral-700">
                情シス・技術部門の方へ
              </span>
              <h3 class="mt-4 text-xl font-bold leading-snug text-navy-950 md:text-2xl">
                要件とユースケースの整理から相談する
              </h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-neutral-700 md:text-base">
                精度・情報漏洩・運用の不安は、作る前の要件とスキーマ設計で大きく減らせます。何をどう聞くAIにするかを一緒に固め、通常RAG／GraphRAGのどれで解くかまで整理します。
              </p>
              <a
                href="/contact?source=services-rag-system-development-persona-it&intent=consult"
                data-cta-source="services-rag-system-development-persona-it"
                data-cta-id="contact-consult"
                class="mt-6 inline-flex min-h-[52px] items-center justify-center rounded-full border-2 border-primary-300 px-6 py-3 text-base font-bold text-primary-700 transition hover:border-primary-500 hover:bg-primary-50"
              >
                要件・構成から相談する
                <svg class="ml-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </Section>
    )}

    {service.id === 'ai-development' && (
      <Section variant="white" padding="lg" decoration="bars">
        <div class="max-w-5xl mx-auto relative z-10">
          <SectionHeader
            title="まずはブラウザで試してみる"
            subtitle="導入前に「実際の挙動」を5分で体感できます"
            number="05"
            label="LIVE DEMOS"
          />
          <div class="grid md:grid-cols-2 gap-6 mb-8">
            <a
              href="/demos/it-advisor"
              class="group block p-6 bg-white rounded-2xl border border-gray-200 shadow-soft hover:shadow-medium hover:border-primary-300 transition"
            >
              <span class="inline-block px-2 py-1 text-xs font-bold bg-primary-50 text-primary-700 rounded-md mb-3">
                チャット (RAG)
              </span>
              <h3 class="text-xl font-bold mb-2 group-hover:text-primary-600 transition">
                AIナレッジ相談（RAG）
              </h3>
              <p class="text-sm text-gray-600 leading-relaxed">
                Beekleのコラム記事を Embedding 検索でRAG参照する相談員AI。社内文書RAG構築の感触を体感できます。
              </p>
              <span class="mt-4 inline-flex items-center text-sm font-medium text-primary-600">
                試してみる →
              </span>
            </a>
            <a
              href="/demos/ocr"
              class="group block p-6 bg-white rounded-2xl border border-gray-200 shadow-soft hover:shadow-medium hover:border-primary-300 transition"
            >
              <span class="inline-block px-2 py-1 text-xs font-bold bg-secondary-50 text-secondary-600 rounded-md mb-3">
                ビジョン (LLM)
              </span>
              <h3 class="text-xl font-bold mb-2 group-hover:text-primary-600 transition">
                AI領収書OCR
              </h3>
              <p class="text-sm text-gray-600 leading-relaxed">
                画像から店舗名・日付・合計・明細を構造化JSONで抽出。帳票OCR + LLM構造化のPoC感触に。
              </p>
              <span class="mt-4 inline-flex items-center text-sm font-medium text-primary-600">
                試してみる →
              </span>
            </a>
          </div>
          <div class="text-center">
            <a
              href="/demos"
              data-cta-source={`services-${service.id}-demos`}
              data-cta-id="demos-index"
              class="inline-flex items-center text-sm font-medium text-primary-600 hover:text-primary-700 transition"
            >
              すべてのAIデモを見る →
            </a>
          </div>
        </div>
      </Section>
    )}

    {service.relatedColumns && service.relatedColumns.length > 0 && (
      <Section variant="lightPurple" padding="lg" decoration="blursPurple">
        <div class="max-w-5xl mx-auto relative z-10">
          <SectionHeader
            title="もっと詳しく知りたい方へ"
            subtitle="このサービスの背景にあるデータ活用の考え方"
            number={service.id === 'ai-development' ? '06' : '05'}
            label="RELATED COLUMNS"
          />
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
            {service.relatedColumns.map((rc) => (
              <a
                href={`/column/${rc.slug}`}
                class="group block bg-white rounded-2xl p-6 shadow-soft hover:shadow-medium hover:border-primary-300 border border-gray-100 transition-all"
              >
                <h3 class="text-base font-bold text-navy-950 mb-2 group-hover:text-primary-600 font-Montserrat leading-snug">
                  {rc.title}
                </h3>
                {rc.description && (
                  <p class="text-sm text-gray-600 leading-relaxed">
                    {rc.description}
                  </p>
                )}
                <span class="mt-3 inline-flex items-center text-xs font-medium text-primary-600">
                  記事を読む →
                </span>
              </a>
            ))}
          </div>
        </div>
      </Section>
    )}

    <ServiceFaq faq={service.faq} number={faqNumber} />

    <!-- CTA -->
    <section class="relative py-20 md:py-32 overflow-hidden bg-navy-950">
      <div class="absolute inset-0 bg-grid-pattern-light opacity-30"></div>
      <div class="pointer-events-none absolute -left-24 top-10 h-72 w-72 rounded-full bg-primary-500/25 blur-3xl" aria-hidden="true"></div>
      <div class="pointer-events-none absolute -right-20 bottom-8 h-64 w-64 rounded-full bg-secondary-500/15 blur-3xl" aria-hidden="true"></div>
      <div class="container mx-auto px-6 md:px-8 max-w-4xl text-center relative z-10">
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-6 font-Montserrat">
          どこから始めるか、無料相談で整理しませんか
        </h2>
        <p class="text-xl text-white/90 mb-10 leading-relaxed">
          業務・データ・既存システムを伺い、小さく検証できる範囲と概算費用の考え方をご案内します。
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={`/contact?source=services-${service.id}-final`}
            data-cta-source={`services-${service.id}-final`}
            data-cta-id="contact"
            class="inline-flex items-center justify-center px-10 py-5 text-xl font-semibold text-accent-950 bg-white rounded-full hover:bg-gray-100 transition-all shadow-strong hover:scale-105 transform"
          >
            無料相談を予約する
            <svg class="w-6 h-6 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
          <a
            href={`/downloads/zero-start?ref=services-${service.id}`}
            data-cta-source={`services-${service.id}-final`}
            data-cta-id="download-zero-start"
            class="inline-flex items-center justify-center px-10 py-5 text-xl font-semibold text-white bg-primary-500 rounded-full hover:bg-primary-600 transition-all shadow-strong hover:scale-105 transform"
          >
            サービス資料をダウンロード
            <svg class="w-6 h-6 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .bg-grid-pattern {
    background-image: linear-gradient(rgba(255, 255, 255, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.1) 1px, transparent 1px);
    background-size: 20px 20px;
  }
</style>
