---
import { Header } from '../components/header';
import JsonLd from '../components/seo/json-ld.astro';
import { ButtonLink } from '../components/ui/button';
import { Card, CardDescription, CardIcon, CardTitle } from '../components/ui/card';
import { Section, SectionHeader } from '../components/ui/section';
import Layout from '../layouts/layout.astro';
---

<Layout
  title="ゼロスタートとは｜初期費用0円のプロトタイプ無料体験で発注前に動くシステムを試す | Beekle"
  description="ゼロスタートとは、Beekleの「プロトタイプ無料体験」サービス。初期費用0円で動くシステムを試せる、新しいシステム発注の形です。見積書だけで判断する不安を解消し、実物を確認してから本契約を決められます。中堅企業のDX担当者向け。"
>
  <JsonLd
    slot="head"
    type="service"
    data={{
      serviceName: 'プロトタイプ無料体験（ゼロスタート）',
      serviceDescription:
        '初期費用0円で動くプロトタイプを体験してから本契約を決められるサービス。見積書と提案資料だけで判断を迫られる不安を解消します。',
      url: 'https://beekle.jp/prooffirst',
      serviceType: 'システム開発プロトタイプ作成',
    }}
  />
  <JsonLd
    slot="head"
    type="breadcrumb"
    data={{
      items: [
        { name: 'ホーム', url: '/' },
        { name: 'プロトタイプ無料体験', url: '/prooffirst' },
      ],
    }}
  />
  <Header client:load />
  <main class="">
    {/* Hero Section */}
    <section class="relative min-h-[calc(100vh-120px)] lg:mx-12 pt-20">
      {/* Background with Pop Style decorations */}
      <div class="absolute inset-0 bg-gradient-to-br from-primary-50/60 via-white to-secondary-50/40 rounded-[48px] overflow-hidden mt-20">
        {/* Pop decoration bars */}
        <div class="absolute -top-10 right-10 w-32 h-96 bg-gradient-to-b from-primary-500 to-primary-300 rounded-full -rotate-[25deg] opacity-10" />
        <div class="absolute top-20 right-32 w-20 h-64 bg-gradient-to-b from-secondary-500 to-secondary-400 rounded-full rotate-[25deg] opacity-10" />
        <div class="absolute -bottom-20 left-20 w-24 h-72 bg-gradient-to-b from-highlight-500 to-highlight-100 rounded-full -rotate-[15deg] opacity-10" />

        {/* Decorative dots */}
        <svg class="absolute top-10 left-10 w-32 h-32 text-primary-500/15" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
          <circle cx="10" cy="10" r="2"/><circle cx="30" cy="10" r="2"/><circle cx="50" cy="10" r="2"/><circle cx="70" cy="10" r="2"/><circle cx="90" cy="10" r="2"/>
          <circle cx="10" cy="30" r="2"/><circle cx="30" cy="30" r="2"/><circle cx="50" cy="30" r="2"/><circle cx="70" cy="30" r="2"/><circle cx="90" cy="30" r="2"/>
          <circle cx="10" cy="50" r="2"/><circle cx="30" cy="50" r="2"/><circle cx="50" cy="50" r="2"/><circle cx="70" cy="50" r="2"/><circle cx="90" cy="50" r="2"/>
        </svg>

        {/* Floating shapes */}
        <div class="absolute top-20 right-20 w-32 h-32 bg-primary-100/40 rounded-full blur-xl animate-float" />
        <div class="absolute bottom-40 left-40 w-48 h-48 bg-secondary-50/50 rounded-full blur-xl animate-float-delay" />
      </div>

      {/* Content */}
      <div class="relative p-8 md:p-12 xl:p-20 border border-primary-500/20 rounded-[48px] mt-20">
        <div class="grid lg:grid-cols-[1.1fr_1fr] gap-12 items-center fade-in-up">
          {/* Left: Copy */}
          <div>
            <div class="mb-6">
              <span class="inline-block px-4 py-2 bg-primary-500/10 text-primary-500 rounded-full text-sm font-medium">
                Beekle × techbeans × AmpTech
              </span>
            </div>

            <h1 class="text-4xl md:text-6xl xl:text-7xl font-semibold leading-tight text-accent-950 mb-6">
              まず、動くものを見よう。
            </h1>

            <p class="text-2xl md:text-3xl font-bold text-accent-950 mb-8 leading-snug">
              話すより、<span class="text-primary-500">Proof（証拠）</span>を。
            </p>

            <p class="text-base md:text-lg text-neutral-700 leading-relaxed mb-10 max-w-xl">
              不確実な見積もり、無限に長い要件定義、言葉のすれ違い。そうした開発の不安を、<span class="font-semibold text-primary-500">"ゼロスタート"</span>がなくします。初期費用0円で動くプロトタイプから始める、新しい開発体験を。
            </p>

            {/* CTA Buttons */}
            <div class="flex flex-col sm:flex-row gap-4">
              <ButtonLink
                href="/contact?source=prooffirst-hero"
                data-cta-source="prooffirst-hero"
                data-cta-id="contact"
                variant="primary"
                size="lg"
              >
                証拠から始める開発を体験する
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </ButtonLink>
            </div>
          </div>

          {/* Right: Dashboard mockup */}
          <div class="relative hidden lg:block">
            {/* Background blob */}
            <div class="absolute -inset-8 bg-gradient-to-br from-primary-100/60 to-secondary-100/40 rounded-[40px] blur-2xl" aria-hidden="true"></div>

            {/* Dashboard card */}
            <div class="relative bg-white rounded-3xl shadow-strong border border-primary-500/10 overflow-hidden">
              {/* Window header */}
              <div class="flex items-center gap-2 px-5 py-3 border-b border-neutral-100 bg-neutral-50/50">
                <span class="w-3 h-3 rounded-full bg-red-400/80" aria-hidden="true"></span>
                <span class="w-3 h-3 rounded-full bg-yellow-400/80" aria-hidden="true"></span>
                <span class="w-3 h-3 rounded-full bg-green-400/80" aria-hidden="true"></span>
                <span class="ml-3 text-xs font-semibold text-neutral-500">ダッシュボード</span>
              </div>

              <div class="p-5 space-y-4">
                {/* KPI row */}
                <div class="grid grid-cols-2 gap-3">
                  <div class="rounded-xl bg-primary-50 p-3">
                    <p class="text-[10px] text-neutral-500 mb-1">月間売上</p>
                    <p class="text-lg font-bold text-primary-500">¥24,560,400</p>
                    <p class="text-[10px] text-green-600 font-semibold mt-0.5">▲ +12.4%</p>
                  </div>
                  <div class="rounded-xl bg-secondary-50 p-3">
                    <p class="text-[10px] text-neutral-500 mb-1">削減コスト</p>
                    <p class="text-lg font-bold text-secondary-600">¥5,240,000</p>
                    <p class="text-[10px] text-green-600 font-semibold mt-0.5">▲ +8.2%</p>
                  </div>
                </div>

                {/* Chart */}
                <div class="rounded-xl border border-neutral-100 p-3 bg-white">
                  <div class="flex items-center justify-between mb-2">
                    <p class="text-[10px] font-semibold text-neutral-600">ROIの推移</p>
                    <p class="text-[10px] text-neutral-400">直近12ヶ月</p>
                  </div>
                  <svg class="w-full h-24" viewBox="0 0 200 80" fill="none" aria-hidden="true">
                    <defs>
                      <linearGradient id="chartFill" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#3D4DB7" stop-opacity="0.25"/>
                        <stop offset="100%" stop-color="#3D4DB7" stop-opacity="0"/>
                      </linearGradient>
                    </defs>
                    <path d="M0 65 L20 60 L40 55 L60 50 L80 42 L100 35 L120 28 L140 22 L160 15 L180 12 L200 8 L200 80 L0 80 Z" fill="url(#chartFill)"/>
                    <path d="M0 65 L20 60 L40 55 L60 50 L80 42 L100 35 L120 28 L140 22 L160 15 L180 12 L200 8" stroke="#3D4DB7" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="200" cy="8" r="3" fill="#3D4DB7"/>
                  </svg>
                </div>

                {/* Bar chart row */}
                <div class="grid grid-cols-7 gap-1.5 items-end h-12">
                  <div class="bg-primary-200 rounded-sm" style="height:40%"></div>
                  <div class="bg-primary-300 rounded-sm" style="height:60%"></div>
                  <div class="bg-primary-400 rounded-sm" style="height:50%"></div>
                  <div class="bg-primary-500 rounded-sm" style="height:80%"></div>
                  <div class="bg-secondary-400 rounded-sm" style="height:70%"></div>
                  <div class="bg-secondary-500 rounded-sm" style="height:90%"></div>
                  <div class="bg-highlight-500 rounded-sm" style="height:100%"></div>
                </div>
              </div>
            </div>

            {/* Floating badge: 初期費用0円 */}
            <div class="absolute -top-6 -right-4 w-24 h-24 bg-highlight-500 rounded-full flex flex-col items-center justify-center shadow-strong rotate-[-12deg] animate-float">
              <span class="text-[10px] font-bold text-accent-950">初期費用</span>
              <span class="text-2xl font-extrabold text-accent-950 leading-none">0<span class="text-base">円</span></span>
            </div>

            {/* Floating badge: リアルタイム可視化 */}
            <div class="absolute top-16 -right-8 bg-white rounded-2xl shadow-medium px-3 py-2 border border-primary-100 animate-float-delay">
              <p class="text-[10px] text-neutral-500">リアルタイム可視化</p>
              <p class="text-sm font-bold text-primary-500">75<span class="text-xs">%</span></p>
            </div>

            {/* Floating badge: ユーザー満足度 */}
            <div class="absolute bottom-12 -right-6 bg-white rounded-2xl shadow-medium px-3 py-2 border border-secondary-100 animate-float">
              <p class="text-[10px] text-neutral-500">ユーザー満足度</p>
              <p class="text-sm font-bold text-secondary-600">4.8 <span class="text-highlight-500">★</span></p>
            </div>

            {/* Floating badge: 実装速度 */}
            <div class="absolute -bottom-4 left-6 bg-white rounded-2xl shadow-medium px-3 py-2 border border-primary-100 animate-float-delay">
              <p class="text-[10px] text-neutral-500">実装速度</p>
              <p class="text-sm font-bold text-primary-500">92<span class="text-xs">%</span></p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Problem Section */}
    <Section variant="lightPurple" padding="lg" decoration="blursMix">
      <SectionHeader
        number="01"
        label="Problem"
        title="「開発って、正直よくわからない。」"
        subtitle="そんな声からゼロスタートは生まれました。"
      />

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        <Card variant="white" padding="md" hover="lift" decoration="barPurple">
          <div class="text-center">
            <div class="mb-4 w-16 h-16 mx-auto text-neutral-400">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-full h-full">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z" />
              </svg>
            </div>
            <h4 class="text-lg font-bold text-accent-950 mb-3">
              エンジニアのことは<br />よくわからない
            </h4>
          </div>
        </Card>

        <Card variant="white" padding="md" hover="lift" decoration="barCyan">
          <div class="text-center">
            <div class="mb-4 w-16 h-16 mx-auto text-neutral-400">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-full h-full">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z" />
              </svg>
            </div>
            <h4 class="text-lg font-bold text-accent-950 mb-3">
              何が正解か<br />わからない
            </h4>
          </div>
        </Card>

        <Card variant="white" padding="md" hover="lift" decoration="dots">
          <div class="text-center">
            <div class="mb-4 w-16 h-16 mx-auto text-neutral-400">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-full h-full">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971Z" />
              </svg>
            </div>
            <h4 class="text-lg font-bold text-accent-950 mb-3">
              見積もりが<br />当てにならない
            </h4>
          </div>
        </Card>

        <Card variant="white" padding="md" hover="lift" decoration="barPurple">
          <div class="text-center">
            <div class="mb-4 w-16 h-16 mx-auto text-neutral-400">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-full h-full">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 0 1 7.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 0 1 1.06 0Z" />
              </svg>
            </div>
            <h4 class="text-lg font-bold text-accent-950 mb-3">
              頼んでも思ったのと<br />違うものが出てくる
            </h4>
          </div>
        </Card>

        <Card variant="white" padding="md" hover="lift" decoration="barCyan">
          <div class="text-center">
            <div class="mb-4 w-16 h-16 mx-auto text-neutral-400">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-full h-full">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z" />
              </svg>
            </div>
            <h4 class="text-lg font-bold text-accent-950 mb-3">
              どこに頼んだら<br />いいかすら不安
            </h4>
          </div>
        </Card>

        <Card variant="white" padding="md" hover="lift" decoration="dots">
          <div class="text-center">
            <div class="mb-4 w-16 h-16 mx-auto text-neutral-400">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-full h-full">
                <path stroke-linecap="round" stroke-linejoin="round" d="m6.75 7.5 3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0 0 21 18V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v12a2.25 2.25 0 0 0 2.25 2.25Z" />
              </svg>
            </div>
            <h4 class="text-lg font-bold text-accent-950 mb-3">
              AIやPoCって聞くけど、<br />自分の会社に合うか分からない
            </h4>
          </div>
        </Card>
      </div>

      <div class="text-center mt-16 max-w-3xl mx-auto">
        <p class="text-xl text-neutral-700 leading-relaxed mb-8">
          表面的には「わからない・怖い・選べない」という不安。<br />
          <span class="font-semibold text-primary-500">不安なのは、当たり前。</span>だから私たちは、<br />
          <span class="text-2xl font-bold text-primary-500">まず動くものを見せることにしました。</span>
        </p>
        <ButtonLink
          href="/contact?source=prooffirst-mid"
          data-cta-source="prooffirst-mid"
          data-cta-id="contact"
          variant="primary"
          size="lg"
        >
          証拠から始める開発を体験する
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </ButtonLink>
      </div>
    </Section>

    {/* Solution Section */}
    <Section variant="white" padding="lg" decoration="blursPurple">
      <SectionHeader
        number="02"
        label="Solution"
        title="正解を話し込むの、やめました。"
        subtitle="会議や見積もりでは、まだ足りない。判断の材料になるのは、会話でも資料でもなく、動くデモの証拠です。"
      />

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <Card variant="white" padding="lg" hover="lift">
          <div class="text-center">
            <CardIcon variant="purple">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8">
                <path d="M8 16c0-4 3-8 8-8h16c5 0 8 4 8 8v8c0 4-3 8-8 8h-4l-6 8v-8h-6c-5 0-8-4-8-8v-8z" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="16" cy="20" r="1.5" fill="currentColor"/>
                <circle cx="24" cy="20" r="1.5" fill="currentColor"/>
                <circle cx="32" cy="20" r="1.5" fill="currentColor"/>
              </svg>
            </CardIcon>
            <CardTitle className="text-2xl text-primary-500 mb-4">実物で合意形成</CardTitle>
            <CardDescription>プロトタイプを前に合意形成が早まる</CardDescription>
          </div>
        </Card>

        <Card variant="white" padding="lg" hover="lift">
          <div class="text-center">
            <CardIcon variant="purple">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8">
                <rect x="8" y="8" width="32" height="32" rx="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M8 16h32M16 8v32" stroke-linecap="round"/>
                <path d="M20 32l4-8 4 6 4-10" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </CardIcon>
            <CardTitle className="text-2xl text-primary-500 mb-4">ROIで判断</CardTitle>
            <CardDescription>効果を数値で可視化して意思決定</CardDescription>
          </div>
        </Card>

        <Card variant="white" padding="lg" hover="lift">
          <div class="text-center">
            <CardIcon variant="purple">
              <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2" class="w-8 h-8">
                <circle cx="24" cy="24" r="16" stroke-linecap="round"/>
                <circle cx="24" cy="24" r="8" stroke-linecap="round"/>
                <circle cx="24" cy="24" r="3" fill="currentColor"/>
                <path d="M24 8v4M24 36v4M8 24h4M36 24h4" stroke-linecap="round"/>
              </svg>
            </CardIcon>
            <CardTitle className="text-2xl text-primary-500 mb-4">上申が実演に</CardTitle>
            <CardDescription>上申資料が「実演デモ」へ置き換わる</CardDescription>
          </div>
        </Card>
      </div>
    </Section>

    {/* Freedom Section */}
    <Section variant="light" padding="lg" decoration="bars">
      <SectionHeader
        number="03"
        label="Freedom"
        title="決める自由を、取り戻そう。"
      />

      <div class="max-w-4xl mx-auto">
        <Card variant="lightPurple" padding="lg" hover="none" className="mb-12">
          <p class="text-xl text-accent-950 leading-relaxed mb-6">
            システム開発は<span class="font-semibold text-primary-500">改善の連続</span>。<br />
            ゼロスタートは終わりではなく、<span class="font-semibold text-primary-500">始まり</span>です。
          </p>

          <p class="text-lg text-neutral-700 leading-relaxed mb-6">
            「どこに頼んでいいかわからない」「何が正解かわからない」――<br />
            そんな不安の中で、見えないものに投資を決めるのは難しい。
          </p>

          <p class="text-lg text-neutral-700 leading-relaxed">
            だからゼロスタートは、<span class="font-semibold text-primary-500">判断するための材料</span>を提供します。<br />
            実際に動くものを見て、触って、効果を確かめてから、<br />
            本格的な開発をスタートする。<span class="font-semibold">判断を先送りにしない</span>、新しい始め方です。
          </p>
        </Card>

        <div class="grid md:grid-cols-2 gap-8">
          <Card variant="outlined" padding="lg" hover="none">
            <h3 class="text-xl font-bold text-accent-950 mb-4 flex items-center">
              <span class="text-3xl mr-3">🚫</span>
              従来の開発
            </h3>
            <ul class="space-y-3 text-neutral-700">
              <li class="flex items-start">
                <span class="text-red-500 mr-2 mt-1">×</span>
                <span>見積もりだけで判断を迫られる</span>
              </li>
              <li class="flex items-start">
                <span class="text-red-500 mr-2 mt-1">×</span>
                <span>完成するまで実物が見えない</span>
              </li>
              <li class="flex items-start">
                <span class="text-red-500 mr-2 mt-1">×</span>
                <span>期待とのギャップが後から発覚</span>
              </li>
              <li class="flex items-start">
                <span class="text-red-500 mr-2 mt-1">×</span>
                <span>大きな初期投資が必要</span>
              </li>
