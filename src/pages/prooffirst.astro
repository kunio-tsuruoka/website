---
import { Header } from '../components/header';
import JsonLd from '../components/seo/json-ld.astro';
import Layout from '../layouts/layout.astro';
---

<Layout
  title="ゼロスタートとは｜初期費用0円のプロトタイプ無料体験で発注前に動くシステムを試す | Beekle"
  description="ゼロスタートとは、Beekleの「プロトタイプ無料体験」サービス。初期費用0円で動くシステムを試せる、新しいシステム発注の形です。見積書だけで判断する不安を解消し、実物を確認してから本契約を決められます。中堅企業のDX担当者向け。"
>
  <JsonLd
    slot="head"
    type="service"
    data={{
      serviceName: 'プロトタイプ無料体験（ゼロスタート）',
      serviceDescription:
        '初期費用0円で動くプロトタイプを体験してから本契約を決められるサービス。見積書と提案資料だけで判断を迫られる不安を解消します。',
      url: 'https://beekle.jp/prooffirst',
      serviceType: 'システム開発プロトタイプ作成',
    }}
  />
  <JsonLd
    slot="head"
    type="breadcrumb"
    data={{
      items: [
        { name: 'ホーム', url: '/' },
        { name: 'プロトタイプ無料体験', url: '/prooffirst' },
      ],
    }}
  />
  <Header client:load />

  <main class="bg-white">
    {/* ============ HERO ============ */}
    <section class="relative pt-24 md:pt-28 pb-12 md:pb-20 overflow-hidden">
      {/* Background decorations */}
      <div class="absolute inset-0 -z-10 pointer-events-none">
        {/* big blue diagonal blob behind dashboard */}
        <div class="absolute top-10 right-0 w-[55%] h-[420px] bg-gradient-to-br from-primary-500/15 via-primary-400/10 to-transparent rounded-[60%] blur-2xl"></div>
        <div class="absolute -top-12 right-12 w-44 h-[380px] bg-primary-500/10 rounded-full -rotate-12"></div>
        <div class="absolute top-32 right-40 w-24 h-64 bg-secondary-500/10 rounded-full rotate-12"></div>
        <div class="absolute -bottom-10 left-20 w-32 h-32 bg-highlight-500/10 rounded-full"></div>
        {/* Decorative dots top-left */}
        <svg class="absolute top-32 left-4 w-20 h-20 text-primary-500/20" viewBox="0 0 100 100" fill="currentColor" aria-hidden="true">
          <circle cx="10" cy="10" r="2"/><circle cx="30" cy="10" r="2"/><circle cx="50" cy="10" r="2"/>
          <circle cx="10" cy="30" r="2"/><circle cx="30" cy="30" r="2"/><circle cx="50" cy="30" r="2"/>
          <circle cx="10" cy="50" r="2"/><circle cx="30" cy="50" r="2"/><circle cx="50" cy="50" r="2"/>
        </svg>
        {/* Yellow squiggle right */}
        <svg class="absolute top-20 right-2 w-10 h-10 text-highlight-500/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" d="M3 12c2-3 4-3 6 0s4 3 6 0 4-3 6 0"/>
        </svg>
      </div>

      <div class="container mx-auto px-6 lg:px-12">
        <div class="grid lg:grid-cols-[1.1fr_1fr] gap-10 lg:gap-12 items-center">
          {/* LEFT: COPY */}
          <div>
            <span class="inline-block px-4 py-1.5 bg-primary-500/10 text-primary-500 rounded-full text-xs md:text-sm font-medium mb-5">
              Beekle <span class="opacity-50 mx-1">×</span> techbeans <span class="opacity-50 mx-1">×</span> AmpTech
            </span>

            <h1 class="text-[1.75rem] sm:text-3xl md:text-4xl lg:text-[2.5rem] xl:text-5xl font-bold leading-[1.2] text-accent-950 mb-4 tracking-tight whitespace-nowrap">
              まず、動くものを見よう。
            </h1>

            <p class="text-2xl md:text-3xl lg:text-[2.25rem] font-bold text-accent-950 mb-6 leading-tight">
              話すより、<span class="text-primary-500">Proof</span><span class="text-primary-500 text-xl md:text-2xl align-baseline">（証拠）</span>を。
            </p>

            <p class="text-sm md:text-base text-neutral-700 leading-relaxed mb-8 max-w-xl">
              不確実な見積もり、長い要件定義、すれ違う認識のギャップ。<br class="hidden md:block"/>
              それ、すべて「まず動くものを見る」ことで解決できます。<br class="hidden md:block"/>
              <span class="text-primary-500 font-semibold">ゼロスタート</span>は、初期費用<span class="text-primary-500 font-bold">0円</span>でプロトタイプを開発。動くものを見てから、次の一手を決められます。
            </p>

            <a
              href="/contact?source=prooffirst-hero"
              data-cta-source="prooffirst-hero"
              data-cta-id="contact"
              class="inline-flex items-center gap-2 px-6 py-3.5 bg-primary-500 hover:bg-primary-600 text-white rounded-full text-sm md:text-base font-semibold shadow-soft hover:shadow-medium transition-all"
            >
              証拠から始める開発を体験する
              <span class="w-7 h-7 rounded-full bg-white/20 flex items-center justify-center">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
              </span>
            </a>
          </div>

          {/* RIGHT: DASHBOARD MOCKUP */}
          <div class="relative">
            {/* glow */}
            <div class="absolute -inset-4 bg-gradient-to-br from-primary-100/50 to-secondary-100/30 rounded-[40px] blur-2xl -z-10" aria-hidden="true"></div>

            {/* Dashboard window */}
            <div class="relative bg-white rounded-2xl shadow-strong border border-neutral-100 overflow-hidden">
              {/* window header */}
              <div class="flex items-center gap-1.5 px-4 py-2.5 border-b border-neutral-100 bg-neutral-50">
                <span class="w-2.5 h-2.5 rounded-full bg-red-400/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-yellow-400/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-green-400/80"></span>
                <span class="ml-3 text-[11px] font-semibold text-neutral-500">ダッシュボード</span>
              </div>

              <div class="p-4 space-y-3">
                {/* KPI tiles */}
                <div class="grid grid-cols-2 gap-2.5">
                  <div class="rounded-lg bg-primary-50/70 p-2.5">
                    <p class="text-[9px] text-neutral-500 mb-0.5">売上 月次</p>
                    <p class="text-sm md:text-base font-bold text-accent-950">¥24,560,400</p>
                    <p class="text-[9px] text-green-600 font-semibold">▲ +24.5%</p>
                  </div>
                  <div class="rounded-lg bg-secondary-50/70 p-2.5">
                    <p class="text-[9px] text-neutral-500 mb-0.5">コスト削減効果</p>
                    <p class="text-sm md:text-base font-bold text-accent-950">¥5,240,000</p>
                    <p class="text-[9px] text-green-600 font-semibold">▲ +32.1%</p>
                  </div>
                </div>

                {/* Chart */}
                <div class="rounded-lg border border-neutral-100 p-3">
                  <p class="text-[10px] font-semibold text-neutral-700 mb-1">ROI 推移</p>
                  <svg class="w-full h-24" viewBox="0 0 220 90" fill="none" aria-hidden="true">
                    <defs>
                      <linearGradient id="hf" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#00c4cc" stop-opacity="0.3"/>
                        <stop offset="100%" stop-color="#00c4cc" stop-opacity="0"/>
                      </linearGradient>
                    </defs>
                    {/* grid */}
                    <line x1="20" y1="15" x2="220" y2="15" stroke="#E5E7EB" stroke-width="0.4" stroke-dasharray="2 2"/>
                    <line x1="20" y1="40" x2="220" y2="40" stroke="#E5E7EB" stroke-width="0.4" stroke-dasharray="2 2"/>
                    <line x1="20" y1="65" x2="220" y2="65" stroke="#E5E7EB" stroke-width="0.4" stroke-dasharray="2 2"/>
                    <text x="14" y="17" font-size="6" fill="#9CA3AF" text-anchor="end">80%</text>
                    <text x="14" y="42" font-size="6" fill="#9CA3AF" text-anchor="end">50%</text>
                    <text x="14" y="67" font-size="6" fill="#9CA3AF" text-anchor="end">20%</text>
                    <path d="M30 70 L62 64 L94 50 L126 38 L158 25 L190 18 L218 10 L218 80 L30 80 Z" fill="url(#hf)"/>
                    <path d="M30 70 L62 64 L94 50 L126 38 L158 25 L190 18 L218 10" stroke="#00c4cc" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="30" cy="70" r="1.6" fill="#00c4cc"/>
                    <circle cx="62" cy="64" r="1.6" fill="#00c4cc"/>
                    <circle cx="94" cy="50" r="1.6" fill="#00c4cc"/>
                    <circle cx="126" cy="38" r="1.6" fill="#00c4cc"/>
                    <circle cx="158" cy="25" r="1.6" fill="#00c4cc"/>
                    <circle cx="190" cy="18" r="2" fill="#00c4cc"/>
                    <circle cx="218" cy="10" r="2.5" fill="#3D4DB7"/>
                    <text x="30" y="88" font-size="6" fill="#9CA3AF" text-anchor="middle">2月</text>
                    <text x="62" y="88" font-size="6" fill="#9CA3AF" text-anchor="middle">3月</text>
                    <text x="94" y="88" font-size="6" fill="#9CA3AF" text-anchor="middle">4月</text>
                    <text x="126" y="88" font-size="6" fill="#9CA3AF" text-anchor="middle">5月</text>
                    <text x="158" y="88" font-size="6" fill="#9CA3AF" text-anchor="middle">6月</text>
                    <text x="190" y="88" font-size="6" fill="#9CA3AF" text-anchor="middle">7月</text>
                  </svg>
                </div>
              </div>
            </div>

            {/* Floating badge: プロトタイプ達成 75% */}
            <div class="absolute -top-3 -right-3 sm:-right-6 bg-white rounded-2xl shadow-medium px-3 py-2 border border-primary-100/80 animate-float">
              <p class="text-[9px] text-neutral-500 leading-none mb-1">プロトタイプ達成</p>
              <p class="text-base sm:text-lg font-bold text-primary-500 leading-none">75<span class="text-xs">%</span></p>
            </div>

            {/* Floating badge: AI予測モデル 精度 92% */}
            <div class="absolute top-1/2 -right-3 sm:-right-8 -translate-y-1/2 bg-white rounded-2xl shadow-medium px-3 py-2 border border-primary-100/80 animate-float-delay">
              <div class="flex items-center gap-2">
                <span class="w-6 h-6 rounded-full bg-secondary-100 flex items-center justify-center text-secondary-600 flex-shrink-0">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.091 3.091Z"/>
                  </svg>
                </span>
                <div>
                  <p class="text-[9px] text-neutral-500 leading-none mb-0.5">AI予測モデル</p>
                  <p class="text-xs sm:text-sm font-bold text-accent-950 leading-none">精度 <span class="text-secondary-600">92%</span></p>
                </div>
              </div>
            </div>

            {/* Floating badge: ユーザー満足度 4.8/5 */}
            <div class="absolute bottom-12 -right-2 sm:-right-6 bg-white rounded-2xl shadow-medium px-3 py-2 border border-secondary-100/80 animate-float">
              <div class="flex items-center gap-2">
                <span class="text-highlight-500">★</span>
                <div>
                  <p class="text-[9px] text-neutral-500 leading-none mb-0.5">ユーザー満足度</p>
                  <p class="text-xs sm:text-sm font-bold text-accent-950 leading-none">4.8<span class="text-[10px] text-neutral-400 font-normal">/5</span></p>
                </div>
              </div>
            </div>

            {/* Floating yellow burst: 初期費用 0円 */}
            <div class="absolute -bottom-4 -right-4 sm:-bottom-6 sm:-right-6 w-24 h-24 sm:w-28 sm:h-28 bg-highlight-500 rounded-full flex flex-col items-center justify-center shadow-strong rotate-[-10deg] animate-float-delay z-10">
              <span class="text-[10px] font-bold text-accent-950">初期費用</span>
              <span class="text-2xl sm:text-3xl font-extrabold text-accent-950 leading-none">0<span class="text-base">円</span></span>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ============ 01 PROBLEM ============ */}
    <section class="relative bg-gradient-to-br from-primary-50/40 via-white to-primary-50/20 py-16 md:py-20 overflow-hidden">
      <div class="absolute top-10 right-10 w-32 h-32 bg-primary-100/30 rounded-full blur-3xl -z-0"></div>
      <div class="absolute bottom-20 left-10 w-32 h-32 bg-secondary-50/40 rounded-full blur-3xl -z-0"></div>

      <div class="container mx-auto px-6 lg:px-12 relative">
        {/* Header */}
        <div class="flex items-baseline gap-4 mb-3">
          <span class="font-Poppins text-3xl md:text-4xl font-bold text-primary-500">01</span>
          <span class="text-xs md:text-sm font-semibold tracking-wider uppercase text-primary-500">Problem</span>
          <h2 class="text-xl md:text-2xl lg:text-3xl font-bold text-accent-950 ml-auto md:ml-6">開発って、正直よくわからない。</h2>
        </div>
        <p class="text-sm text-neutral-600 mb-10 md:mb-12 md:ml-24">そんな声からゼロスタートは生まれました。</p>

        {/* 6 cards */}
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-5 max-w-5xl mx-auto">
          {[
            { icon: 'M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z M9 12a3 3 0 0 1 6 0', label: 'エンジニアのことは\nよくわからない' },
            { icon: 'M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75 M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z M12 17.25h.008v.008H12v-.008Z', label: '何が正解か\nわからない' },
            { icon: 'M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25 M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z M3.75 9h16.5m-16.5 6.75h16.5', label: '見積もりが\n当てにならない', custom: 'M8.25 8.25h7.5v7.5h-7.5z' },
            { icon: 'M15.182 16.318A4.486 4.486 0 0 0 12.016 15a4.486 4.486 0 0 0-3.198 1.318M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z M9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Z', label: '思ったのと違うものが\n出てくる' },
            { icon: 'M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21', label: 'どこに頼んだら\nいいか不安' },
            { icon: 'M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5', label: 'AIやPoCが自社に\n合うかわからない' },
          ].map((item) => (
            <div class="bg-white rounded-2xl p-4 md:p-5 shadow-soft hover:shadow-medium transition-shadow">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-primary-50 flex items-center justify-center text-primary-500 flex-shrink-0">
                  <svg class="w-5 h-5 md:w-6 md:h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={item.icon}/>
                  </svg>
                </div>
                <p class="text-xs md:text-sm font-bold text-accent-950 leading-snug whitespace-pre-line">{item.label}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ============ 02 SOLUTION ============ */}
    <section class="relative bg-white py-16 md:py-20 overflow-hidden">
      <div class="absolute top-10 left-10 w-40 h-40 bg-primary-100/30 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-40 h-40 bg-secondary-50/40 rounded-full blur-3xl"></div>

      <div class="container mx-auto px-6 lg:px-12 relative">
        <div class="flex items-baseline gap-4 mb-10 md:mb-14 flex-wrap">
          <span class="font-Poppins text-3xl md:text-4xl font-bold text-primary-500">02</span>
          <span class="text-xs md:text-sm font-semibold tracking-wider uppercase text-primary-500">Solution</span>
          <h2 class="text-xl md:text-2xl lg:text-3xl font-bold text-accent-950 md:ml-6">正解を話し込むの、やめました。</h2>
        </div>

        <div class="grid md:grid-cols-3 gap-4 md:gap-6 max-w-5xl mx-auto">
          {[
            {
              title: '実物で合意形成',
              desc: 'まず動くプロトタイプを見て、関係者全員で実物の合意形成。認識のズレをゼロにします。',
              iconBg: 'bg-primary-100', iconColor: 'text-primary-500',
              icon: 'M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z',
            },
            {
              title: 'ROIで判断',
              desc: '実データをもとに効果を可視化、投資判断を明確にしてから、次の判断ができます。',
              iconBg: 'bg-secondary-100', iconColor: 'text-secondary-600',
              icon: 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z',
            },
            {
              title: '上申が実演に',
              desc: 'プロトタイプを生で実演。上申資料の説明ジレンマを解消し、社内承認のハードルを下げます。',
              iconBg: 'bg-highlight-100', iconColor: 'text-highlight-600',
              icon: 'M3.375 19.5h17.25m-17.25 0a1.125 1.125 0 0 1-1.125-1.125M3.375 19.5h7.5c.621 0 1.125-.504 1.125-1.125m-9.75 0V5.625m0 12.75v-1.5c0-.621.504-1.125 1.125-1.125m18.375 2.625V5.625m0 12.75c0 .621-.504 1.125-1.125 1.125m1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125m0 3.75h-7.5A1.125 1.125 0 0 1 12 18.375m9.75-12.75c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125m19.5 0v1.5c0 .621-.504 1.125-1.125 1.125M2.25 5.625v1.5c0 .621.504 1.125 1.125 1.125m0 0h17.25m-17.25 0h7.5c.621 0 1.125.504 1.125 1.125M3.375 8.25c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125M12 9.375v9c0 .621-.504 1.125-1.125 1.125M12 9.375a1.125 1.125 0 0 1 1.125-1.125h7.5c.621 0 1.125.504 1.125 1.125M12 9.375v1.5c0 .621.504 1.125 1.125 1.125m0 0h7.5m-7.5 0c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125m7.5-3.75c.621 0 1.125.504 1.125 1.125v1.5c0 .621-.504 1.125-1.125 1.125m-9.75 0h7.5',
            },
          ].map((c) => (
            <div class="bg-white rounded-2xl p-5 md:p-6 shadow-soft hover:shadow-medium transition-all hover:-translate-y-1 border border-neutral-100">
              <div class={`w-12 h-12 md:w-14 md:h-14 rounded-xl ${c.iconBg} flex items-center justify-center ${c.iconColor} mb-4`}>
