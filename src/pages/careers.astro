---
// src/pages/careers.astro
export const prerender = false;

import Layout from '@/layouts/layout.astro';
import { Header } from '../components/header';
import JsonLd from '../components/seo/json-ld.astro';
import { PageHero } from '../components/ui/page-hero';

const siteUrl = 'https://beekle.jp';

const jobPostingJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'JobPosting',
  title: '新卒・インターンエンジニア',
  datePosted: '2026-05-28',
  description:
    'フルリモート・フレックスタイム制のスモールチームで、システム開発の問題解決に取り組むエンジニアを募集',
  employmentType: ['FULL_TIME', 'INTERN'],
  hiringOrganization: {
    '@type': 'Organization',
    '@id': siteUrl,
    name: '株式会社Beekle',
    sameAs: siteUrl,
  },
  jobLocation: {
    '@type': 'Place',
    address: {
      '@type': 'PostalAddress',
      addressLocality: '大田区',
      addressRegion: '東京都',
      addressCountry: 'JP',
    },
  },
  jobLocationType: 'TELECOMMUTE',
  applicantLocationRequirements: {
    '@type': 'Country',
    name: 'JP',
  },
};

const appealCards = [
  {
    title: 'フルリモート・フレックス',
    description:
      'コアタイムはありますが、月の精算時間160時間を超えない限り、いつ働いても構いません。自分のリズムで集中できる環境です。',
    icon: 'M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25',
    iconBg: 'bg-primary-100',
    iconColor: 'text-primary-500',
  },
  {
    title: 'スモールチームの意思決定',
    description:
      '少人数だからこそ、一人ひとりの判断がプロダクトに直結します。「提案して、すぐ試せる」スピード感があります。',
    icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
    iconBg: 'bg-secondary-100',
    iconColor: 'text-secondary-600',
  },
  {
    title: '自走 + 相談できる安心感',
    description:
      '基本は自分で考えて動く文化ですが、困ったときはSlackで気軽に相談できます。論理的で優しい人が集まっています。',
    icon: 'M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155',
    iconBg: 'bg-highlight-100',
    iconColor: 'text-highlight-600',
  },
  {
    title: '個性を尊重する社風',
    description:
      '人それぞれの得意分野や働き方を尊重します。釣り好きの副社長、多言語話者の社長、多様なバックグラウンドのチームです。',
    icon: 'M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z',
    iconBg: 'bg-primary-100',
    iconColor: 'text-primary-500',
  },
];

const recruitmentDetails = [
  { label: '募集対象', value: '新卒（2027年卒）、インターン' },
  { label: '雇用形態', value: '正社員（新卒）、インターン' },
  {
    label: '勤務形態',
    value: 'フレックスタイム制（コアタイムあり、月精算160時間）',
  },
  {
    label: '勤務地',
    value: 'フルリモート（本社: 東京都大田区久が原3-14-27）',
  },
  { label: '休日・休暇', value: '完全週休2日制' },
  { label: '試用期間', value: '3ヶ月（条件同一）' },
  {
    label: '福利厚生',
    value: '社会保険完備（健康保険・厚生年金・雇用保険・労災保険）',
  },
];

const desiredTraits = [
  '問題解決のプロセスを楽しめる人',
  '自分で調べて試してみる習慣がある人',
  '技術に限らず「なぜ？」を考えるのが好きな人',
  'チームで成果を出すことにやりがいを感じる人',
  '完璧でなくていい、学ぶ意欲がある人',
];

const workItems = [
  {
    title: '発注側に立ったシステム開発支援',
    description: 'お客様の「やりたいこと」を技術で形にするために、発注者の視点に立って伴走します。',
    icon: 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z',
  },
  {
    title: '要件定義からPoC、本番開発まで一貫サポート',
    description: '上流の要件整理からプロトタイプ検証、本番リリースまで一気通貫で対応します。',
    icon: 'M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z',
  },
  {
    title: '生成AI活用の開発プロセス',
    description:
      'Claude CodeやCursorなどの生成AIツールを日常的に活用し、効率的に開発を進めています。',
    icon: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.091 3.091zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z',
  },
  {
    title: '中堅企業のDX推進パートナー',
    description:
      '「IT部門がない」「何から始めればいいかわからない」という企業の伴走役として、DXを支援しています。',
    icon: 'M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21',
  },
];
---

<Layout
  title="新卒・インターン採用 | Beekle"
  description="Beekle株式会社の新卒・インターン採用情報。フルリモート・フレックスタイム制。論理的で優しいスモールチームで、問題解決が好きな仲間を募集しています。"
>
  <JsonLd
    slot="head"
    type="breadcrumb"
    data={{
      items: [
        { name: 'ホーム', url: '/' },
        { name: '採用情報', url: '/careers' },
      ],
    }}
  />
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(jobPostingJsonLd)}
  />
  <Header client:load />

  <main class="pt-20">
    <!-- Hero -->
    <PageHero
      badge="Careers"
      title="新卒・インターン採用"
      subtitle="問題解決が好きな人と、一緒に考えたい。"
    />

    <!-- 01: なぜBeekleで働くのか -->
    <section class="py-20 md:py-28">
      <div class="container mx-auto px-6 lg:px-12">
        <div class="text-center mb-12 md:mb-16">
          <div class="flex items-baseline justify-center gap-4 mb-3">
            <span class="font-Poppins text-3xl md:text-4xl font-bold text-primary-500">01</span>
            <span class="text-xs md:text-sm font-semibold tracking-wider uppercase text-primary-500">Culture</span>
          </div>
          <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-accent-950">なぜBeekleで働くのか</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6 max-w-5xl mx-auto">
          {appealCards.map((card) => (
            <div class="bg-white rounded-2xl p-6 md:p-7 shadow-soft hover:shadow-medium transition-all hover:-translate-y-1 border border-neutral-100">
              <div class={`w-12 h-12 md:w-14 md:h-14 rounded-xl ${card.iconBg} flex items-center justify-center ${card.iconColor} mb-4`}>
                <svg class="w-6 h-6 md:w-7 md:h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={card.icon} />
                </svg>
              </div>
              <h3 class="text-base md:text-lg font-bold text-accent-950 mb-2">{card.title}</h3>
              <p class="text-sm text-neutral-700 leading-relaxed">{card.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 02: Beekleの仕事 -->
    <section class="py-20 md:py-28 bg-gray-50">
      <div class="container mx-auto px-6 lg:px-12">
        <div class="text-center mb-12 md:mb-16">
          <div class="flex items-baseline justify-center gap-4 mb-3">
            <span class="font-Poppins text-3xl md:text-4xl font-bold text-primary-500">02</span>
            <span class="text-xs md:text-sm font-semibold tracking-wider uppercase text-primary-500">Work</span>
          </div>
          <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-accent-950">Beekleの仕事</h2>
          <p class="mt-4 text-sm md:text-base text-neutral-600 max-w-2xl mx-auto leading-relaxed">
            Beekleは「発注者の側に立つ」システム開発会社です。お客様が安心して発注判断できるよう、上流から下流まで一貫して支援しています。
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6 max-w-5xl mx-auto">
          {workItems.map((item) => (
            <div class="bg-white rounded-2xl p-6 shadow-soft border border-neutral-100">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-primary-50 flex items-center justify-center text-primary-500 flex-shrink-0">
                  <svg class="w-5 h-5 md:w-6 md:h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                  </svg>
                </div>
                <div>
                  <h3 class="text-sm md:text-base font-bold text-accent-950 mb-1">{item.title}</h3>
                  <p class="text-xs md:text-sm text-neutral-600 leading-relaxed">{item.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 03: 募集要項 -->
    <section class="py-20 md:py-28">
      <div class="container mx-auto px-6 lg:px-12">
        <div class="text-center mb-12 md:mb-16">
          <div class="flex items-baseline justify-center gap-4 mb-3">
            <span class="font-Poppins text-3xl md:text-4xl font-bold text-primary-500">03</span>
            <span class="text-xs md:text-sm font-semibold tracking-wider uppercase text-primary-500">Requirements</span>
          </div>
          <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-accent-950">募集要項</h2>
        </div>

        <div class="max-w-3xl mx-auto">
          <div class="bg-white rounded-2xl shadow-soft border border-neutral-100 overflow-hidden">
            <div class="divide-y divide-neutral-100">
              {recruitmentDetails.map((row) => (
                <div class="flex flex-col sm:flex-row py-4 px-6">
                  <dt class="sm:w-40 font-bold text-accent-950 text-sm mb-1 sm:mb-0 flex-shrink-0">{row.label}</dt>
                  <dd class="flex-1 text-neutral-700 text-sm">{row.value}</dd>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 04: こんな人を歓迎します -->
    <section class="py-20 md:py-28 bg-gray-50">
      <div class="container mx-auto px-6 lg:px-12">
        <div class="text-center mb-12 md:mb-16">
          <div class="flex items-baseline justify-center gap-4 mb-3">
            <span class="font-Poppins text-3xl md:text-4xl font-bold text-primary-500">04</span>
            <span class="text-xs md:text-sm font-semibold tracking-wider uppercase text-primary-500">People</span>
          </div>
          <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-accent-950">こんな人を歓迎します</h2>
        </div>

        <div class="max-w-2xl mx-auto">
          <ul class="space-y-4">
            {desiredTraits.map((trait) => (
              <li class="flex items-start gap-3 bg-white rounded-xl p-4 shadow-soft border border-neutral-100">
                <span class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                </span>
                <span class="text-sm md:text-base text-accent-950 font-medium">{trait}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- 05: CTA -->
    <section class="py-20 md:py-28 bg-accent-950">
      <div class="container mx-auto px-6 lg:px-12">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-white mb-6">
            まずは話を聞いてみませんか？
          </h2>
          <p class="text-white/80 text-sm md:text-base leading-relaxed mb-10 max-w-xl mx-auto">
            選考前のカジュアル面談も歓迎です。Beekleの雰囲気や仕事内容について、気軽にお話しましょう。
          </p>
          <a
            href="/contact?source=careers"
            data-cta-source="careers-bottom"
            data-cta-id="contact"
            class="inline-flex items-center gap-2 px-8 py-4 bg-primary-500 hover:bg-primary-600 text-white rounded-full text-base font-semibold shadow-soft hover:shadow-medium transition-all"
          >
            お問い合わせはこちら
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
