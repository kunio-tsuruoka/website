---
import { Header } from '../../components/header';
import JsonLd from '../../components/seo/json-ld.astro';
import { PageHero } from '../../components/ui/page-hero';
import Layout from '../../layouts/layout.astro';
import { type MicroCMSEnv, PILLAR_SLUGS, getColumns } from '../../lib/microcms';

export const prerender = false;

const runtime = (Astro.locals as { runtime?: { env?: MicroCMSEnv } }).runtime;
const env = runtime?.env;

const pillarSlug = PILLAR_SLUGS['genai-adoption'];
const allColumns = await getColumns('genai-adoption', env);
const pillar = allColumns.find((c) => c.id === pillarSlug);
const articles = allColumns
  .filter((c) => c.id !== pillarSlug)
  .map((c) => ({
    id: c.id,
    title: c.title,
    description: c.description,
    publishedAt: c.publishedAt,
  }));
---

<Layout
  title="生成AI導入のコラム一覧 | Beekle"
  description="生成AI導入を検討する担当者・情シス・経営層向けのコラム一覧です。何から始めるか、費用対効果、セキュリティ対策、PoCから本番化まで、導入の進め方を判断材料つきで解説しています。"
>
  <JsonLd
    slot="head"
    type="breadcrumb"
    data={{
      items: [
        { name: 'ホーム', url: '/' },
        { name: '発注者向けコラム', url: '/column' },
        { name: '生成AI導入', url: '/column/genai-adoption' },
      ],
    }}
  />
  {allColumns.length > 0 && (
    <JsonLd
      slot="head"
      type="itemList"
      data={{
        name: '生成AI導入 コラム一覧',
        url: 'https://beekle.jp/column/genai-adoption',
        itemType: 'Article',
        items: allColumns.map((a) => ({
          name: a.title,
          ...(a.description ? { description: a.description } : {}),
          url: `https://beekle.jp/column/${a.id}`,
        })),
      }}
    />
  )}
  <Header client:load />
  <main class="pt-20">
    <PageHero
      title="生成AI導入"
      subtitle="何から始めるか、費用、セキュリティ、失敗の避け方まで。導入を検討する担当者・情シス・経営層向けのコラムです"
      badge="Generative AI Adoption"
    />

    <section class="py-16 md:py-24">
      <div class="container mx-auto px-6 md:px-8 max-w-3xl">
        {pillar && (
          <a
            href={`/column/${pillar.id}`}
            class="block p-6 md:p-8 mb-12 rounded-2xl border-2 border-primary-200 bg-primary-50/50 hover:border-primary-400 hover:shadow-medium transition-all group"
          >
            <p class="text-xs font-semibold text-primary-500 tracking-wide mb-2">
              まず読む完全ガイド
            </p>
            <h2 class="text-xl md:text-2xl font-bold text-gray-900 group-hover:text-primary-500 transition-colors leading-tight mb-3">
              {pillar.title}
            </h2>
            {pillar.description && (
              <p class="text-gray-600 text-sm leading-relaxed line-clamp-3">
                {pillar.description}
              </p>
            )}
          </a>
        )}

        <div class="divide-y divide-gray-200">
          {articles.map((article) => (
            <a href={`/column/${article.id}`} class="block py-8 first:pt-0 last:pb-0 group">
              <time class="text-sm text-gray-500">
                {new Date(article.publishedAt).toLocaleDateString('ja-JP')}
              </time>
              <h2 class="text-lg md:text-xl font-bold text-gray-900 group-hover:text-primary-500 transition-colors mt-1 mb-2 leading-tight">
                {article.title}
              </h2>
              {article.description && (
                <p class="text-gray-600 text-sm leading-relaxed line-clamp-2">
                  {article.description}
                </p>
              )}
            </a>
          ))}
        </div>

        {allColumns.length === 0 && (
          <div class="text-center py-16 bg-gray-50 rounded-xl">
            <p class="text-gray-500">
              記事を読み込めませんでした。しばらくしてから再度お試しください。
            </p>
          </div>
        )}

        <div class="mt-16 p-6 md:p-8 rounded-2xl bg-accent-950 text-white text-center">
          <h2 class="text-lg md:text-xl font-bold mb-3">生成AI導入、小さく始めてみませんか？</h2>
          <p class="text-white/80 text-sm leading-relaxed mb-6">
            どの業務から始めるか・費用・セキュリティまで、導入の進め方を無料でご相談いただけます。初期費用0円で動くデモから試せる「ゼロスタート開発」の資料も配布しています。
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a
              href="/contact?source=genai-adoption-page&intent=genai-adoption"
              data-cta-source="genai-adoption-page"
              data-cta-id="consult-genai-adoption"
              class="inline-flex items-center justify-center px-6 py-3 min-h-[44px] bg-primary-500 text-white rounded-full text-sm font-semibold hover:bg-primary-600 transition-colors"
            >
              生成AI導入を相談する（無料）
            </a>
            <a
              href="/downloads/zero-start?source=genai-adoption-page&intent=genai-adoption"
              data-cta-source="genai-adoption-page"
              data-cta-id="download-zero-start"
              class="inline-flex items-center justify-center px-6 py-3 min-h-[44px] bg-white/10 border border-white/30 text-white rounded-full text-sm font-semibold hover:bg-white/20 transition-colors"
            >
              サービス資料を無料DL
            </a>
          </div>
        </div>

        <div class="mt-12 text-center">
          <a
            href="/column"
            class="inline-flex items-center text-primary-500 hover:text-primary-600 font-semibold transition-colors group py-3"
          >
            <svg
              class="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            <span>コラム一覧を見る</span>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
