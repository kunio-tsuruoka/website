---
import ContactForm from '../components/contact-form';
import { Header } from '../components/header';
import JsonLd from '../components/seo/json-ld.astro';
import { PageHero } from '../components/ui/page-hero';
import Layout from '../layouts/layout.astro';

const runtime = (Astro.locals as { runtime?: { env?: { TURNSTILE_SITE_KEY?: string } } }).runtime;
const sitekey = runtime?.env?.TURNSTILE_SITE_KEY ?? '0x4AAAAAADHmRrTyQk-jx5-X';

const trustPoints = [
  {
    title: '通常1〜2営業日で返信',
    body: '営業時間内なら当日返信も多いです。返信が無い場合はメール受信を再度ご確認ください。',
  },
  {
    title: '無料相談・しつこい営業なし',
    body: 'ご検討段階のご相談歓迎。「合わなさそう」と感じた場合の連絡停止もメール1通で完了します。',
  },
  {
    title: '初期費用0円のゼロスタート開発',
    body: '見積書ではなく動くプロトタイプから判断できる仕組みもご用意しています。',
  },
];
---

<Layout
  title="お問い合わせ | Beekle"
  description="Beekleへのお問い合わせページ。Webアプリ・モバイルアプリ・AI開発のご相談、お見積もりなどお気軽にご連絡ください。初期費用0円のゼロスタート開発についてもこちらからお問い合わせいただけます。"
>
  <JsonLd
    slot="head"
    type="breadcrumb"
    data={{
      items: [
        { name: 'ホーム', url: '/' },
        { name: 'お問い合わせ', url: '/contact' },
      ],
    }}
  />
  <Header client:load />
  <main class="pt-20">
    <PageHero
      title="お問い合わせ"
      subtitle="プロジェクトのご相談・お見積もり・資料請求など、お気軽にご連絡ください。通常1〜2営業日以内にご返信します。"
    />

    <section class="py-20 md:py-28">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto">
          <div class="grid sm:grid-cols-3 gap-4 mb-10">
            {trustPoints.map((p) => (
              <div class="bg-white border border-primary-100 rounded-2xl p-5 shadow-soft">
                <p class="text-sm font-bold text-primary-700 mb-1">{p.title}</p>
                <p class="text-xs text-foreground/70 leading-relaxed">{p.body}</p>
              </div>
            ))}
          </div>

          <div class="mb-8 rounded-2xl bg-primary-50 border border-primary-100 p-5">
            <p class="text-sm text-foreground/85 leading-relaxed">
              事前に資料で全体像を把握したい方は
              <a href="/downloads/zero-start?source=contact-trust" class="text-primary-600 font-medium underline hover:no-underline">ゼロスタート開発サービス資料(無料)</a>
              もご利用ください。実例や対象企業がまとまっています。
            </p>
          </div>

          <ContactForm client:load sitekey={sitekey} />

          <details class="mt-8 rounded-xl border border-amber-200 bg-amber-50 p-5 md:p-6">
            <summary class="cursor-pointer font-semibold text-gray-800 list-none flex items-center justify-between">
              <span>営業・売り込み目的のご連絡について</span>
              <span class="text-gray-500 text-sm">クリックで詳細</span>
            </summary>
            <div class="space-y-3 text-sm text-gray-700 mt-4">
              <div>
                <p class="font-semibold text-primary-500 mb-1">歓迎するご提案</p>
                <ul class="list-disc list-inside space-y-1 ml-2">
                  <li>開発パートナーとしての協業</li>
                  <li>当社サービスに関連する技術・ツールのご紹介</li>
                  <li>共同プロジェクトや事業提携のご相談</li>
                </ul>
              </div>
              <div>
                <p class="font-semibold text-red-600 mb-1">お断りしているご連絡</p>
                <ul class="list-disc list-inside space-y-1 ml-2">
                  <li>一方的な営業・セールスメール</li>
                  <li>当社の事業内容と無関係なサービスの売り込み</li>
                  <li>テンプレートを使用した大量送信型の営業メッセージ</li>
                </ul>
                <p class="mt-2 text-gray-500">
                  上記に該当するご連絡には返信いたしかねますので、ご了承ください。
                </p>
              </div>
            </div>
          </details>
        </div>
      </div>
    </section>
  </main>

  <script
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer></script>
</Layout>
