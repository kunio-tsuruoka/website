---
import ContactForm from '../components/contact-form';
import { Header } from '../components/header';
import { PageHero } from '../components/ui/page-hero';
import Layout from '../layouts/layout.astro';
---

<Layout
  title="お問い合わせ | Beekle"
  description="Beekleへのお問い合わせページ。Webアプリ・モバイルアプリ・AI開発のご相談、お見積もりなどお気軽にご連絡ください。初期費用0円のゼロスタート開発についてもこちらからお問い合わせいただけます。"
>
  <Header client:load />
  <main class="pt-20">
    <PageHero
      title="お問い合わせ"
      subtitle="プロジェクトのご相談・お見積もり・資料請求など、お気軽にご連絡ください。通常1〜2営業日以内にご返信します。"
    />

    <section class="py-20 md:py-28">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto">
          <ContactForm client:load />

          <details class="mt-8 rounded-xl border border-amber-200 bg-amber-50 p-5 md:p-6">
            <summary class="cursor-pointer font-semibold text-gray-800 list-none flex items-center justify-between">
              <span>営業・売り込み目的のご連絡について</span>
              <span class="text-gray-500 text-sm">クリックで詳細</span>
            </summary>
            <div class="space-y-3 text-sm text-gray-700 mt-4">
              <div>
                <p class="font-semibold text-primary-500 mb-1">歓迎するご提案</p>
                <ul class="list-disc list-inside space-y-1 ml-2">
                  <li>開発パートナーとしての協業</li>
                  <li>当社サービスに関連する技術・ツールのご紹介</li>
                  <li>共同プロジェクトや事業提携のご相談</li>
                </ul>
              </div>
              <div>
                <p class="font-semibold text-red-600 mb-1">お断りしているご連絡</p>
                <ul class="list-disc list-inside space-y-1 ml-2">
                  <li>一方的な営業・セールスメール</li>
                  <li>当社の事業内容と無関係なサービスの売り込み</li>
                  <li>テンプレートを使用した大量送信型の営業メッセージ</li>
                </ul>
                <p class="mt-2 text-gray-500">
                  上記に該当するご連絡には返信いたしかねますので、ご了承ください。
                </p>
              </div>
            </div>
          </details>
        </div>
      </div>
    </section>
  </main>
</Layout>
