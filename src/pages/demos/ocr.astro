---
import { AiOcrDemo } from '@/features/ai-ocr-demo';
import { Header } from '../../components/header';
import FloatingCTA from '../../components/ui/floating-cta.astro';
import { PageHero } from '../../components/ui/page-hero';
import Layout from '../../layouts/layout.astro';

const runtime = (Astro.locals as { runtime?: { env?: { TURNSTILE_SITE_KEY?: string } } }).runtime;
const sitekey = runtime?.env?.TURNSTILE_SITE_KEY ?? '0x4AAAAAADHmRrTyQk-jx5-X';
---

<Layout
  title="AI領収書OCR (デモ)｜画像から店舗名・金額・明細を自動抽出 | Beekle"
  description="領収書の画像をアップロードすると、AIが店舗名・日付・合計・明細を自動抽出します。経費精算の効率化を体感できるデモ。業務での精度検証はBeekleが支援します。"
>
  <Header client:load />
  <main class="pt-20">
    <PageHero
      title="AI領収書OCR (デモ)"
      subtitle="領収書の画像から店舗名・日付・金額・明細をAIが抽出します。経費精算や請求業務の自動化を試せるデモです。"
      badge="AI Demo"
    />

    <section class="py-12 md:py-16 bg-gradient-to-br from-gray-50 to-white">
      <div class="container mx-auto px-6 md:px-8 max-w-6xl">
        <AiOcrDemo client:load sitekey={sitekey} />

        <div class="mt-10 grid md:grid-cols-3 gap-4 text-sm">
          <div class="p-5 bg-white rounded-2xl border border-gray-200">
            <p class="font-bold mb-2">用途</p>
            <p class="text-gray-600">経費精算の自動化、請求書処理、書類整理などの効率化を検討する際の感触確認に。</p>
          </div>
          <div class="p-5 bg-white rounded-2xl border border-gray-200">
            <p class="font-bold mb-2">注意</p>
            <p class="text-gray-600">手書き・かすれた領収書では精度が落ちます。業務利用には精度検証と運用設計が必要です。</p>
          </div>
          <div class="p-5 bg-white rounded-2xl border border-gray-200">
            <p class="font-bold mb-2">プライバシー</p>
            <p class="text-gray-600">画像はOCR処理のみに利用し、サーバには保存しません。AI応答には店舗名・金額のみ含まれます。</p>
          </div>
        </div>
      </div>
    </section>

    <FloatingCTA source="tool-ai-ocr-demo" />
  </main>

  <script
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer></script>
</Layout>
