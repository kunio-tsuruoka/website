---
import { Header } from '../components/header';
import { PageHero } from '../components/ui/page-hero';
import Layout from '../layouts/layout.astro';
import { type MicroCMSEnv, getQACategories, getQAs } from '../lib/microcms';

const runtime = (Astro.locals as { runtime?: { env?: MicroCMSEnv } }).runtime;
const env = runtime?.env;

let qaCategories: Awaited<ReturnType<typeof getQACategories>> = [];
let allQAs: Awaited<ReturnType<typeof getQAs>> = [];
let apiError: string | null = null;

try {
  qaCategories = await getQACategories(env);
  allQAs = await getQAs(undefined, env);
} catch (error) {
  console.error('Failed to load QA data:', error);
  apiError = error instanceof Error ? error.message : 'Unknown error';
}

const qaByCategory = qaCategories
  .map((category) => ({
    ...category,
    items: allQAs.filter((qa) => qa.category?.id === category.id),
  }))
  .sort((a, b) => a.order - b.order);

const description =
  'システム開発の発注に関するよくある質問に、Beekleが一問一答形式でお答えします。見積もり、要件定義、ベンダー選定、プロジェクト管理など、発注側が抱きがちな疑問を解消します。';
---

<Layout
  title="一問一答 - システム開発の発注に関するよくある質問 | Beekle"
  description={description}
>
  <Header client:load />
  <main class="pt-20">
    <PageHero
      title="一問一答"
      subtitle="システム開発の発注で多くの方が抱える疑問に、要点を絞ってお答えします。"
      badge="Q&A"
    >
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#categories"
          class="inline-flex items-center justify-center px-8 py-4 text-lg font-medium text-primary-500 bg-white rounded-full hover:bg-gray-100 transition-all shadow-lg hover:shadow-xl"
        >
          質問を見る
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
        <a
          href="/contact?source=qa-hero"
          data-cta-source="qa-hero"
          data-cta-id="contact"
          class="inline-flex items-center justify-center px-8 py-4 text-lg font-medium text-white bg-transparent border-2 border-white rounded-full hover:bg-white hover:text-primary-500 transition-all"
        >
          直接相談する
        </a>
      </div>
    </PageHero>

    {apiError && (
      <section class="py-8">
        <div class="container mx-auto px-6 md:px-8">
          <div class="bg-gray-50 rounded-xl p-8 text-center">
            <p class="text-gray-600">現在コンテンツを読み込めません。しばらくしてから再度お試しください。</p>
          </div>
        </div>
      </section>
    )}

    {/* Category Quick Nav */}
    {qaByCategory.length > 0 && (
      <section class="py-10 bg-white border-b border-gray-100">
        <div class="container mx-auto px-6 md:px-8">
          <div class="flex flex-wrap justify-center gap-3">
            {qaByCategory.map((category) => (
              <a
                href={`#${category.id}`}
                class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-primary-50 to-primary-100 hover:from-primary-100 hover:to-primary-200 text-primary-600 rounded-full font-medium transition-all shadow-sm hover:shadow-md"
              >
                {category.icon && <span>{category.icon}</span>}
                <span>{category.title}</span>
                <span class="text-xs text-primary-400">({category.items.length})</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* QA List */}
    <section id="categories" class="py-16 md:py-24 bg-gradient-to-br from-gray-50 to-white">
      <div class="container mx-auto px-6 md:px-8 max-w-4xl">
        {qaByCategory.length === 0 && !apiError && (
          <div class="text-center py-16 bg-white rounded-2xl shadow-sm">
            <p class="text-gray-500">準備中です。もうしばらくお待ちください。</p>
          </div>
        )}

        {qaByCategory.map((category, idx) => (
          <div id={category.id} class="mb-16 scroll-mt-24">
            <div class="mb-8">
              <div class="flex items-center gap-4 mb-3">
                <div class="w-14 h-14 flex-shrink-0 rounded-2xl bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center shadow-lg text-white font-Poppins text-xl font-bold">
                  {String(idx + 1).padStart(2, '0')}
                </div>
                <div class="flex-1">
                  <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-1">
                    {category.icon && <span class="mr-2">{category.icon}</span>}
                    {category.title}
                  </h2>
                  {category.description && (
                    <p class="text-gray-600">{category.description}</p>
                  )}
                </div>
              </div>
              <div class="border-t-2 border-primary-200"></div>
            </div>

            {category.items.length > 0 ? (
              <div class="space-y-4">
                {category.items.map((item) => (
                  <details class="group bg-white rounded-2xl shadow-md hover:shadow-lg transition-shadow border border-gray-100 overflow-hidden">
                    <summary class="flex items-start gap-4 p-6 md:p-7 cursor-pointer list-none">
                      <span class="flex-shrink-0 w-10 h-10 rounded-full bg-primary-500 text-white font-bold flex items-center justify-center text-sm">
                        Q
                      </span>
                      <h3 class="flex-1 text-lg md:text-xl font-bold text-gray-900 leading-snug pt-1.5">
                        {item.question}
                      </h3>
                      <span class="flex-shrink-0 w-8 h-8 rounded-full bg-gray-100 group-hover:bg-primary-100 flex items-center justify-center transition-all">
                        <svg
                          class="w-4 h-4 text-gray-600 group-open:rotate-180 transition-transform"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                      </span>
                    </summary>

                    <div class="px-6 md:px-7 pb-6 md:pb-7">
                      <div class="flex items-start gap-4 pt-2 border-t border-gray-100">
                        <span class="flex-shrink-0 w-10 h-10 rounded-full bg-secondary-500 text-white font-bold flex items-center justify-center text-sm mt-4">
                          A
                        </span>
                        <div
                          class="flex-1 prose prose-sm md:prose-base max-w-none pt-4 text-gray-700"
                          set:html={item.answer}
                        />
                      </div>

                      {item.tags && (
                        <div class="mt-4 flex flex-wrap gap-2 pl-14">
                          {item.tags.split(',').map((tag) => (
                            <span class="inline-block px-3 py-1 text-xs bg-gray-100 text-gray-600 rounded-full">
                              #{tag.trim()}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </details>
                ))}
              </div>
            ) : (
              <div class="text-center py-10 bg-white rounded-xl border border-gray-100">
                <p class="text-gray-500">このカテゴリーの質問はまだありません</p>
              </div>
            )}
          </div>
        ))}
      </div>
    </section>

    {/* CTA */}
    <section class="relative py-20 md:py-28 overflow-hidden bg-gradient-to-br from-primary-500 to-primary-600">
      <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
      <div class="container mx-auto px-6 md:px-8 relative">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
            ここに無い質問は、<br class="md:hidden" />直接ご相談ください
          </h2>
          <p class="text-lg text-white/90 mb-10 leading-relaxed">
            状況に合わせた具体的な回答をお返しします。匿名相談・初回無料です。
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href="/contact?source=qa-final"
              data-cta-source="qa-final"
              data-cta-id="contact"
              class="inline-flex items-center justify-center px-10 py-5 text-lg font-semibold text-primary-500 bg-white rounded-full hover:bg-gray-100 transition-all shadow-xl hover:shadow-2xl"
            >
              無料相談を予約する
              <svg class="w-5 h-5 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
            <a
              href="/column"
              class="inline-flex items-center justify-center px-10 py-5 text-lg font-semibold text-white bg-transparent border-2 border-white rounded-full hover:bg-white hover:text-primary-500 transition-all"
            >
              コラムで詳しく学ぶ
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  details > summary::-webkit-details-marker { display: none; }
  details[open] summary span:last-child { background-color: rgb(219 209 255); }

  .bg-grid-pattern {
    background-image: linear-gradient(rgba(255, 255, 255, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.1) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .scroll-mt-24 { scroll-margin-top: 6rem; }
</style>
