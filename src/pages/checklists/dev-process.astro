---
import { Renderer, marked } from 'marked';
import { Header } from '../../components/header';
import JsonLd from '../../components/seo/json-ld.astro';
// 同期: public/docs/dev-process-checklist.md（ダウンロード配信用）
import rawMarkdown from '../../data/dev-process-checklist.md?raw';
import Layout from '../../layouts/layout.astro';
import { type TocItem, slugify } from '../../lib/toc';

const toc: TocItem[] = [];
const renderer = new Renderer();

renderer.heading = ({ text, depth }) => {
  if (depth === 2 || depth === 3) {
    const id = slugify(text);
    toc.push({ id, text, level: depth });
    return `<h${depth} id="${id}">${text}</h${depth}>`;
  }
  return `<h${depth}>${text}</h${depth}>`;
};

renderer.listitem = ({ text, task, checked }) => {
  if (task) {
    const className = checked ? 'checkbox checked' : 'checkbox unchecked';
    const cleanText = text.replace(/<input[^>]*>/, '').trim();
    return `<li class="${className}">${cleanText}</li>\n`;
  }
  return `<li>${text}</li>\n`;
};

marked.setOptions({ breaks: true, gfm: true });
marked.use({ renderer });

const htmlContent = marked(rawMarkdown) as string;

const pageTitle = '開発プロセスチェックリスト｜要求からBDDまでつなげる7フェーズ';
const pageDescription =
  '対話の記録から要求整理・優先度付け・ユーザーストーリー・Gherkin・BDDまで、システム開発を成功させるための7フェーズの実践チェックリスト。各フェーズの「やること」「判断ポイント」「成果物」を明確化し、発注側・開発側の合意形成を支えます。';
const canonical = 'https://beekle.jp/checklists/dev-process';
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  ogType="article"
>
  <JsonLd
    slot="head"
    type="breadcrumb"
    data={{
      items: [
        { name: 'ホーム', url: '/' },
        { name: 'コラム', url: '/column' },
        { name: '開発プロセスチェックリスト', url: '/checklists/dev-process' },
      ],
    }}
  />
  <JsonLd
    slot="head"
    type="article"
    data={{
      title: pageTitle,
      description: pageDescription,
      url: canonical,
      articleSection: '開発プロセス',
      keywords: '開発プロセス,チェックリスト,要件定義,Gherkin,BDD,ユーザーストーリー,Beekle',
      about: [
        { name: 'Beekle株式会社', url: 'https://beekle.jp' },
        { name: '開発プロセス' },
      ],
    }}
  />
  <Header client:load />
  <main class="pt-20">
    {/* Breadcrumb */}
    <section class="py-6 bg-gray-50 border-b border-gray-200">
      <div class="container mx-auto px-6 md:px-8">
        <nav class="flex items-center gap-2 text-sm text-gray-600">
          <a href="/" class="hover:text-primary-500 transition-colors">ホーム</a>
          <span>/</span>
          <a href="/column" class="hover:text-primary-500 transition-colors">コラム</a>
          <span>/</span>
          <span class="text-gray-900">開発プロセスチェックリスト</span>
        </nav>
      </div>
    </section>

    {/* Hero */}
    <section class="py-12 md:py-16 bg-gradient-to-br from-primary-50 to-primary-100">
      <div class="container mx-auto px-6 md:px-8 max-w-4xl">
        <div class="flex flex-wrap items-center gap-3 mb-6">
          <span class="inline-flex items-center px-3 py-1 bg-primary-500 text-white text-xs font-bold rounded-full">
            チェックリスト
          </span>
          <span class="text-sm text-gray-600">Beekleの普段行っている開発に沿って</span>
        </div>
        <h1 class="text-3xl md:text-5xl font-bold text-gray-900 leading-tight mb-6">
          開発プロジェクトを失敗させないための<br class="hidden md:inline" />
          開発プロセスチェックリスト
        </h1>
        <p class="text-lg text-gray-700 leading-relaxed mb-8">
          要求の整理から優先度付け、ユーザーストーリーとシナリオ化、Gherkinによる受け入れ条件の合意、BDDでの実装まで。各フェーズで「やること」「判断ポイント」「成果物」が明確になっているかを、プロジェクト開始前と途中の節目で確認できる7フェーズのチェックリストです。
        </p>
        <a
          href="/docs/dev-process-checklist.md"
          download="dev-process-checklist.md"
          class="inline-flex items-center px-6 py-3 text-base font-semibold text-white bg-primary-500 rounded-full hover:bg-primary-600 transition-all shadow-md hover:shadow-lg"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Markdownでダウンロード
        </a>
      </div>
    </section>

    {/* Table of Contents */}
    {toc.length > 0 && (
      <section class="py-8 bg-white border-b border-gray-100">
        <div class="container mx-auto px-6 md:px-12 max-w-3xl">
          <nav class="bg-gray-50 rounded-2xl p-6">
            <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
              </svg>
              目次
            </h2>
            <ul class="space-y-2">
              {toc.map((item) => (
                <li class={item.level === 3 ? 'ml-4' : ''}>
                  <a
                    href={`#${item.id}`}
                    class="text-gray-600 hover:text-primary-500 transition-colors text-sm block py-1"
                  >
                    {item.level === 3 && <span class="text-gray-400 mr-1">─</span>}
                    {item.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </section>
    )}

    {/* Content */}
    <article class="py-16 md:py-24 bg-white">
      <div class="container mx-auto px-6 md:px-12 max-w-3xl">
        <div class="markdown-content">
          <Fragment set:html={htmlContent} />
        </div>
      </div>
    </article>

    {/* Back to column */}
    <section class="py-12 bg-white">
      <div class="container mx-auto px-6 md:px-8 max-w-4xl">
        <a
          href="/column"
          class="inline-flex items-center text-primary-500 hover:text-primary-600 font-semibold transition-colors group"
        >
          <svg class="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          <span>コラム一覧に戻る</span>
        </a>
      </div>
    </section>

    {/* CTA */}
    <section class="py-16 md:py-20 bg-accent-950 text-white">
      <div class="container mx-auto px-6 md:px-8 max-w-4xl text-center">
        <h2 class="text-2xl md:text-3xl font-bold mb-4">プロセスを「製品」として標準装備したいなら</h2>
        <p class="text-white/80 leading-relaxed mb-8">
          PM on Rails は、このチェックリストの各項目を、人手とエクセルではなく機能として備えたプロダクトです。
          ご興味のある方はお気軽にお問い合わせください。
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact?source=checklists-dev-final"
            data-cta-source="checklists-dev-final"
            data-cta-id="contact"
            class="inline-flex items-center justify-center px-8 py-3 text-base font-semibold text-primary-500 bg-white rounded-full hover:bg-gray-100 transition-all shadow-lg"
          >
            無料相談を予約する
          </a>
          <a
            href="/column"
            class="inline-flex items-center justify-center px-8 py-3 text-base font-semibold text-white bg-transparent border-2 border-white rounded-full hover:bg-white hover:text-accent-950 transition-all"
          >
            コラムで学ぶ
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .markdown-content {
    @apply text-gray-800 text-lg leading-loose;
  }

  .markdown-content :global(h2) {
    @apply font-bold text-gray-900 text-2xl md:text-3xl mt-16 mb-6 pb-3 border-b-4 border-primary-400;
    scroll-margin-top: 6rem;
  }

  .markdown-content :global(h3) {
    @apply font-bold text-gray-900 text-xl md:text-2xl mt-12 mb-4 relative pl-5;
    scroll-margin-top: 6rem;
  }

  .markdown-content :global(h3)::before {
    content: '';
    @apply absolute left-0 w-1.5 bg-gradient-to-b from-primary-500 to-primary-600 rounded;
    top: 0.2em;
    height: 1.3em;
  }

  .markdown-content :global(p) {
    @apply text-gray-700 text-lg leading-loose mb-6;
  }

  .markdown-content :global(strong) {
    @apply font-bold text-primary-700;
    background: linear-gradient(180deg, transparent 60%, rgba(199, 210, 254, 0.4) 60%);
    padding: 0 0.2em;
  }

  .markdown-content :global(em) {
    @apply italic text-gray-700;
  }

  .markdown-content :global(ul) {
    @apply my-6 pl-0 list-none;
  }

  .markdown-content :global(ul li) {
    @apply relative text-gray-700 text-lg leading-loose pl-6 mb-3;
  }

  .markdown-content :global(ul li):last-child {
    @apply mb-0;
  }

  .markdown-content :global(ul li)::before {
    content: '';
    @apply absolute left-1 rounded-full;
    top: 0.7em;
    width: 8px;
    height: 8px;
    background: linear-gradient(135deg, #3D4DB7, #3544a4);
    box-shadow: 0 0 0 3px rgba(61, 77, 183, 0.15);
  }

  .markdown-content :global(li.checkbox) {
    @apply relative text-gray-700 text-lg leading-loose pl-10 mb-3;
  }

  .markdown-content :global(li.checkbox)::before {
    content: none;
  }

  .markdown-content :global(li.checkbox.checked)::before {
    content: '';
    @apply absolute left-0 w-6 h-6 rounded-full;
    top: 0.35em;
    background: linear-gradient(135deg, #10B981, #059669);
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.2);
  }

  .markdown-content :global(li.checkbox.checked)::after {
    content: '';
    @apply absolute;
    left: 8px;
    top: 0.55em;
    width: 6px;
    height: 10px;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  .markdown-content :global(li.checkbox.unchecked)::before {
    content: '';
    @apply absolute left-0 w-6 h-6 rounded border-2 border-gray-300 bg-white;
    top: 0.35em;
  }

  .markdown-content :global(ol) {
    @apply my-6 pl-0 list-none;
    counter-reset: item;
  }

  .markdown-content :global(ol li) {
    @apply relative text-gray-700 text-lg leading-loose pl-12 mb-4;
    counter-increment: item;
  }

  .markdown-content :global(ol li):last-child {
    @apply mb-0;
  }

  .markdown-content :global(ol li)::before {
    content: counter(item);
    @apply absolute left-0 w-8 h-8 text-white rounded-full flex items-center justify-center font-bold text-sm;
    background: linear-gradient(135deg, #3D4DB7, #3544a4);
    top: 0.15em;
  }

  .markdown-content :global(hr) {
    @apply border-0;
    margin-top: 64px;
    margin-bottom: 64px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #e0e7ff, transparent);
  }
</style>
