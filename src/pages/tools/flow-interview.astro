---
import { FlowInterview } from '@/features/flow-interview';
import { Header } from '../../components/header';
import JsonLd from '../../components/seo/json-ld.astro';
import FloatingCTA from '../../components/ui/floating-cta.astro';
import { PageHero } from '../../components/ui/page-hero';
import Layout from '../../layouts/layout.astro';

const runtime = (Astro.locals as { runtime?: { env?: { TURNSTILE_SITE_KEY?: string } } }).runtime;
const sitekey = runtime?.env?.TURNSTILE_SITE_KEY ?? '0x4AAAAAADHmRrTyQk-jx5-X';
---

<Layout
  title="話すだけ発注準備｜AIと話すだけで現状業務フロー(As-Is)を可視化 | Beekle"
  description="AIとの会話に答えるだけで、今の業務の流れを業務フロー図(As-Is)としてリアルタイムに可視化。テキストでも音声でも入力でき、できた図はそのまま編集・相談に進めます。会員登録不要・ブラウザ完結。"
>
  <JsonLd
    slot="head"
    type="softwareApplication"
    data={{
      appName: '会話で業務フロー図化ツール（Flow Interview）',
      appDescription:
        'AIとの対話で現状業務フロー(As-Is)を可視化。テキスト/音声入力対応。会員登録不要・ブラウザ完結。',
      url: 'https://beekle.jp/tools/flow-interview',
    }}
  />
  <JsonLd
    slot="head"
    type="breadcrumb"
    data={{
      items: [
        { name: 'ホーム', url: '/' },
        { name: '発注準備キット', url: '/tools' },
        { name: '会話で業務フロー図化', url: '/tools/flow-interview' },
      ],
    }}
  />

  <Header client:load />
  <main class="pt-20">
    <PageHero
      title="話すだけ発注準備"
      subtitle="AIの質問に答えるだけで、今の業務の流れ（As-Is）がリアルタイムで図になります。テキストでも音声でも回答OK。できた図はそのまま編集したり、Beekleへの相談に進めます。"
      badge="AI Tool"
    />

    <section class="py-12 md:py-16 bg-gradient-to-br from-gray-50 to-white">
      <div class="container mx-auto px-6 md:px-8 max-w-6xl">
        <FlowInterview client:load sitekey={sitekey} />

        <div class="mt-10 grid md:grid-cols-3 gap-4 text-sm">
          <div class="p-5 bg-white rounded-2xl border border-gray-200">
            <p class="font-bold mb-2">話すだけで図になる</p>
            <p class="text-gray-600">
              業務の流れを言葉で説明するだけ。AIが担当・順序・使うツールを整理して図にします。
            </p>
          </div>
          <div class="p-5 bg-white rounded-2xl border border-gray-200">
            <p class="font-bold mb-2">そのまま編集できる</p>
            <p class="text-gray-600">
              できた図はフローマッパーで自由に編集。コスト試算やPNG/SVG出力にも対応します。
            </p>
          </div>
          <div class="p-5 bg-white rounded-2xl border border-gray-200">
            <p class="font-bold mb-2">プライバシー</p>
            <p class="text-gray-600">
              入力内容はBeekle社内の確認用のみに使用します。会員登録は不要です。
            </p>
          </div>
        </div>
      </div>
    </section>

    <FloatingCTA source="flow-interview" />
  </main>

  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
</Layout>
