---
import { Header } from '../../components/header';
import { StoryBuilder } from '../../components/story-builder';
import { PageHero } from '../../components/ui/page-hero';
import Layout from '../../layouts/layout.astro';
---

<Layout
  title="ユーザーストーリー作成ツール｜EARS変換と異常系AI生成 | Beekle"
  description="As a / I want / So that 形式のユーザーストーリーをEARS記法に変換し、見落としがちな異常系シナリオをAIで自動生成。要件定義の抜け漏れを防ぐブラウザツール。"
>
  <Header client:load />
  <main class="pt-20">
    <PageHero
      title="ユーザーストーリー作成ツール"
      subtitle="ユーザーストーリーをEARS記法の要求文に変換し、Unwanted（異常系）シナリオをAIが提案します。要件定義のレビュー前に抜け漏れチェックを。"
      badge="Tools"
    />

    <section class="py-12 md:py-16 bg-gradient-to-br from-gray-50 to-white">
      <div class="container mx-auto px-6 md:px-8 max-w-7xl">
        <div class="mb-8 p-6 bg-white rounded-2xl border border-gray-200 shadow-soft">
          <h2 class="text-lg font-bold text-gray-900 mb-3">使い方</h2>
          <ol class="list-decimal list-inside space-y-1.5 text-sm text-gray-700 leading-relaxed">
            <li>「サンプルを試す」を押すか、対象システム名と <code class="px-1 py-0.5 bg-gray-100 rounded text-xs">As a / I want / So that</code> を入力します</li>
            <li>「正常系を展開」でテンプレートからEARS要求文（Ubiquitous / Event / State）を生成します</li>
            <li>「異常系を生成」で AI（Claude Haiku via OpenRouter）が見落としがちな失敗パターンを提案します</li>
            <li>結果はMarkdownでダウンロードまたはクリップボードにコピーできます</li>
          </ol>
          <p class="mt-3 text-xs text-gray-500">
            参考：<a href="/column" class="text-primary-500 hover:underline">EARS記法とユーザーストーリーの解説コラム</a>
          </p>
        </div>

        <StoryBuilder client:load />
      </div>
    </section>

    <section class="py-16 bg-accent-950 text-white">
      <div class="container mx-auto px-6 md:px-8 max-w-4xl text-center">
        <h2 class="text-2xl md:text-3xl font-bold mb-4">要件定義の伴走、お任せください</h2>
        <p class="text-white/80 leading-relaxed mb-8">
          ユーザーストーリーや異常系シナリオの整理でお困りでしたら、お気軽にご相談ください。
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-8 py-3 text-base font-semibold text-primary-500 bg-white rounded-full hover:bg-gray-100 transition-all shadow-lg"
          >
            無料相談を予約する
          </a>
          <a
            href="/tools/scope-manager"
            class="inline-flex items-center justify-center px-8 py-3 text-base font-semibold text-white bg-transparent border-2 border-white rounded-full hover:bg-white hover:text-accent-950 transition-all"
          >
            スコープ管理ツールを試す
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
