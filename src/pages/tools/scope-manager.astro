---
import { Header } from '../../components/header';
import { ScopeManager } from '../../components/scope-manager';
import { PageHero } from '../../components/ui/page-hero';
import Layout from '../../layouts/layout.astro';
---

<Layout
  title="スコープ管理ツール｜要件をFM形式で優先度判定 | Beekle"
  description="EARS記法で書かれたユーザーストーリーMarkdownを取り込み、ビジネス価値・現場で使えるか・技術コストの3軸で『作る／後回し／作らない』を判定できるブラウザツール。"
>
  <Header client:load />
  <main class="pt-20">
    <PageHero
      title="スコープ管理ツール"
      subtitle="ユーザーストーリー仕様書を取り込み、要求文ごとに優先度を判定。FM（ファンクショナリティ・マトリクス）形式で「作る／後回し／作らない」を可視化します。"
      badge="Tools"
    />

    <section class="py-12 md:py-16 bg-gradient-to-br from-gray-50 to-white">
      <div class="container mx-auto px-6 md:px-8 max-w-7xl">
        {/* 使い方 */}
        <div class="mb-8 p-6 bg-white rounded-2xl border border-gray-200 shadow-soft">
          <h2 class="text-lg font-bold text-gray-900 mb-3">使い方</h2>
          <ol class="list-decimal list-inside space-y-1.5 text-sm text-gray-700 leading-relaxed">
            <li>「サンプルを試す」を押すか、お手元のMarkdown仕様書を貼り付けてください</li>
            <li>「要求文を抽出」を押すと、<code class="px-1 py-0.5 bg-gray-100 rounded text-xs">REQ-XXX-NNN</code> 形式の要求文を自動で表に展開します</li>
            <li>各要求について <strong>ビジネス価値</strong>・<strong>現場で使えるか</strong>・<strong>技術コスト</strong> を1〜3で評価し、<strong>作る／後回し／作らない</strong> を判定してください</li>
            <li>3項目すべて評価したら「判定を自動推定」ボタンで提案させることもできます（最終判断はご自身で）</li>
            <li>結果はCSV / Markdown で出力できます。社内共有や開発会社との合意形成にお使いください</li>
          </ol>
          <p class="mt-3 text-xs text-gray-500">
            参考：<a href="https://blogs.itmedia.co.jp/magic/2021/08/fm.html" target="_blank" rel="noopener noreferrer" class="text-primary-500 hover:underline">FM（ファンクショナリティ・マトリクス）について</a> ／
            <a href="/docs/user-stories-sample.md" download class="text-primary-500 hover:underline">サンプル仕様書をダウンロード</a>
          </p>
        </div>

        <ScopeManager client:load />
      </div>
    </section>

    {/* CTA */}
    <section class="py-16 bg-accent-950 text-white">
      <div class="container mx-auto px-6 md:px-8 max-w-4xl text-center">
        <h2 class="text-2xl md:text-3xl font-bold mb-4">要件整理から開発まで、伴走します</h2>
        <p class="text-white/80 leading-relaxed mb-8">
          ユーザーストーリーの書き方やスコープの絞り込みでお困りでしたら、お気軽にご相談ください。
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact"
            class="inline-flex items-center justify-center px-8 py-3 text-base font-semibold text-primary-500 bg-white rounded-full hover:bg-gray-100 transition-all shadow-lg"
          >
            無料相談を予約する
          </a>
          <a
            href="/column"
            class="inline-flex items-center justify-center px-8 py-3 text-base font-semibold text-white bg-transparent border-2 border-white rounded-full hover:bg-white hover:text-accent-950 transition-all"
          >
            コラムで学ぶ
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
