---
import DownloadZeroStartForm from '../../components/download-zero-start-form';
import { Header } from '../../components/header';
import JsonLd from '../../components/seo/json-ld.astro';
import Layout from '../../layouts/layout.astro';

const runtime = (Astro.locals as { runtime?: { env?: { TURNSTILE_SITE_KEY?: string } } }).runtime;
const sitekey = runtime?.env?.TURNSTILE_SITE_KEY ?? '0x4AAAAAADHmRrTyQk-jx5-X';

const heroBullets = [
  '初期費用0円・成果連動でリスクを最小化する仕組み',
  '見積書ではなく「動くプロトタイプ」で判断する流れ',
  '採用判断材料・実例ベースの導入ステップ',
];

const audience = [
  {
    title: 'システム発注を検討中のDX担当者',
    body: '見積書とPowerPointの提案だけで判断せざるを得ない不安を解消したい方',
  },
  {
    title: '社内稟議の判断材料が不足している方',
    body: '上層部に「動くものを見てから決める」という選択肢を共有したい方',
  },
  {
    title: '小さく始めて段階的に拡張したい方',
    body: '一気に大型契約を結ぶのではなく、効果を確認しながら投資判断したい方',
  },
];

const contents = [
  '従来のシステム開発発注の構造的な課題',
  'ゼロスタート開発の仕組みと、初期費用0円が成立する理由',
  'プロトタイプから本契約までの流れ（フェーズ別の判断ポイント）',
  '対象となる企業規模・業種・プロジェクト種別',
  '実際の進行事例と、判断時に確認すべきチェックポイント',
];
---

<Layout
  title="ゼロスタート開発 サービス資料 | 初期費用0円で動くプロトタイプから判断 | Beekle"
  description="Beekleのゼロスタート開発サービス資料を無料でダウンロードいただけます。初期費用0円で動くプロトタイプを体験し、見積書ではなく実際の動作で判断する仕組み・対象企業・進行プロセスをまとめた資料です。"
>
  <JsonLd
    slot="head"
    type="breadcrumb"
    data={{
      items: [
        { name: 'ホーム', url: '/' },
        { name: '資料ダウンロード', url: '/downloads/zero-start' },
      ],
    }}
  />
  <JsonLd
    slot="head"
    type="service"
    data={{
      serviceName: 'ゼロスタート開発（サービス資料ダウンロード）',
      serviceDescription:
        '初期費用0円で動くプロトタイプを体験してから本契約を決められるシステム開発サービス。発注前の判断材料となる資料を無料配布しています。',
      url: 'https://beekle.jp/downloads/zero-start',
      serviceType: 'システム開発サービス資料',
    }}
  />
  <Header client:load />
  <main class="pt-20 bg-neutral-50">
    {/* Hero */}
    <section class="relative bg-gradient-to-br from-primary-500 to-primary-700 py-16 md:py-24 overflow-hidden">
      <div class="absolute inset-0 bg-grid-pattern opacity-10" />
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <span class="inline-block px-4 py-2 bg-white/15 backdrop-blur-sm text-white rounded-full text-sm font-medium mb-6">
              無料資料ダウンロード
            </span>
            <h1 class="text-3xl md:text-5xl font-bold text-white leading-tight mb-6">
              ゼロスタート開発<br />
              <span class="text-highlight-300">サービス資料</span>
            </h1>
            <p class="text-lg text-white/90 leading-relaxed mb-6">
              初期費用0円で動くプロトタイプを体験し、見積書ではなく実際の動作で判断する開発の仕組みをまとめた資料です。
            </p>
            <ul class="space-y-3 mb-8">
              {heroBullets.map((b) => (
                <li class="flex items-start gap-3 text-white">
                  <span class="flex-shrink-0 inline-flex items-center justify-center w-6 h-6 rounded-full bg-highlight-300 text-accent-950 mt-0.5">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  </span>
                  <span class="text-base md:text-lg">{b}</span>
                </li>
              ))}
            </ul>
            <div class="text-sm text-white/70">
              <span class="inline-flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                PDF / 約20ページ / 無料
              </span>
            </div>
          </div>

          {/* PDF mock card */}
          <div class="relative hidden lg:block">
            <div class="absolute -inset-4 bg-white/10 rounded-3xl blur-2xl" />
            <div class="relative bg-white rounded-2xl shadow-strong p-8 transform rotate-1">
              <div class="aspect-[4/5] bg-gradient-to-br from-primary-50 to-secondary-50 rounded-xl flex flex-col items-center justify-center p-8 border border-primary-100">
                <span class="inline-block px-3 py-1 bg-primary-500 text-white text-xs font-bold rounded-full mb-6">
                  Beekle 公式資料
                </span>
                <svg class="w-16 h-16 text-primary-500 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <h2 class="text-xl font-bold text-accent-950 text-center mb-3">
                  ゼロスタート開発<br />サービスデック
                </h2>
                <p class="text-sm text-foreground/70 text-center">
                  初期費用0円で動くものから判断する<br />システム開発の仕組み
                </p>
                <div class="mt-6 text-xs text-muted-foreground">2026年版</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Audience */}
    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
        <div class="text-center mb-12">
          <p class="text-primary-500 font-semibold mb-2">FOR</p>
          <h2 class="text-2xl md:text-3xl font-bold text-accent-950">こんな方におすすめ</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {audience.map((a) => (
            <div class="bg-white rounded-2xl p-6 md:p-8 shadow-soft border border-neutral-100">
              <h3 class="text-lg font-bold text-accent-950 mb-3">{a.title}</h3>
              <p class="text-sm text-foreground/70 leading-relaxed">{a.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Contents + Form */}
    <section class="py-16 md:py-20 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
        <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-start">
          <div>
            <p class="text-primary-500 font-semibold mb-2">CONTENTS</p>
            <h2 class="text-2xl md:text-3xl font-bold text-accent-950 mb-6">
              資料の中身
            </h2>
            <ol class="space-y-4 mb-8">
              {contents.map((c, i) => (
                <li class="flex items-start gap-4">
                  <span class="flex-shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-full bg-primary-500 text-white font-bold text-sm">
                    {i + 1}
                  </span>
                  <span class="text-base text-foreground/85 leading-relaxed pt-1">{c}</span>
                </li>
              ))}
            </ol>
            <div class="bg-primary-50 border border-primary-100 rounded-2xl p-6">
              <p class="text-sm text-foreground/80 leading-relaxed">
                <strong class="text-primary-700">補足：</strong>
                資料DL後、しつこい営業の電話・大量メールはお送りしません。担当者から1通だけ「ご質問があればどうぞ」とご連絡を差し上げる場合があります（不要であれば無視していただいて結構です）。
              </p>
            </div>
          </div>

          <div id="form">
            <DownloadZeroStartForm client:load sitekey={sitekey} />
          </div>
        </div>
      </div>
    </section>

    {/* Related */}
    <section class="py-16 md:py-20">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
        <div class="text-center mb-10">
          <h2 class="text-2xl md:text-3xl font-bold text-accent-950">関連ページ</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          <a href="/prooffirst" class="block bg-white rounded-2xl p-6 shadow-soft border border-neutral-100 hover:border-primary-300 hover:shadow-medium transition-all min-h-[44px]">
            <h3 class="font-bold text-accent-950 mb-2">プロトタイプ無料体験</h3>
            <p class="text-sm text-foreground/70">ゼロスタート開発の詳細・進行ステップ</p>
          </a>
          <a href="/case-studies" class="block bg-white rounded-2xl p-6 shadow-soft border border-neutral-100 hover:border-primary-300 hover:shadow-medium transition-all min-h-[44px]">
            <h3 class="font-bold text-accent-950 mb-2">開発実績</h3>
            <p class="text-sm text-foreground/70">これまで手がけた開発事例</p>
          </a>
          <a href="/contact?source=download-zero-start-related" class="block bg-white rounded-2xl p-6 shadow-soft border border-neutral-100 hover:border-primary-300 hover:shadow-medium transition-all min-h-[44px]">
            <h3 class="font-bold text-accent-950 mb-2">直接相談する</h3>
            <p class="text-sm text-foreground/70">資料ではなく15分の相談から始める</p>
          </a>
        </div>
      </div>
    </section>

    {/* Final CTA */}
    <section class="py-16 md:py-20 bg-accent-950">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
          まずは資料で全体像をつかんでください
        </h2>
        <p class="text-white/80 mb-8">
          ご質問・ご相談はいつでも歓迎します。資料DL後の対応もお気軽にどうぞ。
        </p>
        <a
          href="#form"
          class="inline-flex items-center justify-center px-8 py-4 min-h-[52px] rounded-full font-semibold text-accent-950 bg-highlight-300 hover:bg-highlight-200 transition-colors shadow-soft hover:shadow-medium"
        >
          フォームに戻る
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" /></svg>
        </a>
      </div>
    </section>
  </main>

  <script
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer></script>
</Layout>
